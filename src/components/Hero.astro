---
// src/components/Hero.astro
// Layout 91 split-hero: copy + CTA left | optimised Image right
// Uses astro:assets <Image /> for Core Web Vitals (LCP optimisation)
// import { Image } from 'astro:assets';
// import heroImg from '../assets/hero-waste-facility.jpg';
---

<section class="relative overflow-hidden bg-brand-dark pt-8 pb-16 lg:pt-16 lg:pb-24">

  <!-- Background image — real <img> so browser discovers it in HTML for LCP -->
  <img
    src="/wastewize-tipper-in-central-london.webp"
    alt=""
    fetchpriority="high"
    loading="eager"
    decoding="async"
    class="pointer-events-none absolute inset-0 w-full h-full object-cover object-left opacity-50"
    aria-hidden="true"
  />

  <!-- Overlay to fade right side toward dark so form stays crisp -->
  <div
    class="pointer-events-none absolute inset-0 bg-gradient-to-r from-transparent via-transparent to-brand-dark"
    aria-hidden="true"
  />

  <div class="container mx-auto px-4 relative">
    <div class="grid lg:grid-cols-2 gap-12 lg:gap-20 items-center">

      <!-- ── LEFT: Copy ── -->
      <div class="max-w-xl">

        <!-- Eyebrow badge -->
        <div class="inline-flex items-center gap-2 bg-brand-lime/10 border border-brand-lime/30
                    rounded-full px-4 py-1.5 mb-6">
          <span class="w-2 h-2 rounded-full bg-brand-lime" aria-hidden="true"/>
          <span class="text-xs font-semibold tracking-wide uppercase text-brand-lime">
            Trusted across London &amp; Home Counties
          </span>
        </div>

        <!-- Main headline -->
        <h1 class="font-display text-4xl sm:text-5xl lg:text-[3.25rem] font-extrabold
                    leading-[1.08] text-white mb-3">
          Waste Removal <em class="not-italic text-brand-lime">London</em>
          <span class="block">&amp; Home Counties</span>
        </h1>

        <!-- H2: keyword signal -->
        <h2 class="text-lg sm:text-xl font-semibold text-white/50 mb-5">
          EA-Licensed Waste Removal &amp; Recycling — London &amp; the Home Counties
        </h2>

        <!-- Sub-copy -->
        <p class="text-[17px] leading-relaxed text-white/60 mb-8 max-w-lg">
          EA-licensed house clearances, commercial waste collections, and specialist disposal for homeowners and businesses across London &amp; the Home Counties. 99% landfill diversion. Same-day and next-day availability.
        </p>

        <!-- CTAs -->
        <div class="flex flex-wrap gap-4 mb-10">
          <a
           href="/contact#quote"
  class="inline-flex items-center gap-2 border border-white/20 text-white
         px-7 py-4 rounded-[8px] text-base font-semibold
         hover:border-brand-lime/50 hover:text-brand-lime hover:-translate-y-0.5
         transition-all duration-200 focus-visible:outline focus-visible:outline-2
         focus-visible:outline-brand-lime focus-visible:outline-offset-2"
>
  Get a Free Quote
  <svg class="w-5 h-5 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
    <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/>
  </svg>
</a>
          <a
            href="tel:+447929771954"
            class="inline-flex items-center gap-2 bg-brand-forest text-white
                   px-7 py-4 rounded-[8px] text-base font-semibold
                   hover:bg-brand-forest-dark hover:-translate-y-0.5 hover:shadow-cta
                   transition-all duration-200 focus-visible:outline focus-visible:outline-2
                   focus-visible:outline-brand-lime focus-visible:outline-offset-2"
          >
            <svg class="w-5 h-5 shrink-0" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
              <path d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z"/>
            </svg>
            Call 07929 771954
          </a>
          <a
            href="tel:+447498363345"
            class="inline-flex items-center gap-2 bg-brand-forest text-white
                   px-7 py-4 rounded-[8px] text-base font-semibold
                   hover:bg-brand-forest-dark hover:-translate-y-0.5 hover:shadow-cta
                   transition-all duration-200 focus-visible:outline focus-visible:outline-2
                   focus-visible:outline-brand-lime focus-visible:outline-offset-2"
          >
            <svg class="w-5 h-5 shrink-0" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
              <path d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z"/>
            </svg>
            Call 07498 363345
          </a>
        </div>

        <!-- Quick-trust row -->
        <div class="flex flex-wrap items-center gap-x-6 gap-y-2 text-sm text-white/50">
          {[
            'EA Licensed',
            'Same-Day Collections',
            'SafeContractor Approved',
          ].map((badge) => (
            <span class="flex items-center gap-1.5">
              <svg class="w-4 h-4 text-brand-lime shrink-0" fill="currentColor" viewBox="0 0 20 20"
                   aria-hidden="true">
                <path fill-rule="evenodd"
                      d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"
                      clip-rule="evenodd"/>
              </svg>
              {badge}
            </span>
          ))}
        </div>
      </div>

      <!-- ── RIGHT: Contact form ── -->
      <div class="w-full">
        <div class="bg-brand-dark-card/10 backdrop-blur-sm border border-white/10 rounded-[20px] p-4 sm:p-6 shadow-float">

          <h2 class="text-base font-semibold text-white mb-0.5">Get a Free Quote</h2>
          <p class="text-xs text-white/50 mb-4">We'll get back to you within 2 hours.</p>

          <form
            method="POST"
            action="#"
            class="flex flex-col gap-3"
            novalidate
          >

            <!-- Name -->
            <div class="flex flex-col gap-1.5">
              <label for="hero-name" class="text-xs font-medium text-white/60 uppercase tracking-wide">
                Full Name <span class="text-brand-lime">*</span>
              </label>
              <input
                id="hero-name"
                name="name"
                type="text"
                required
                placeholder="John Smith"
                class="w-full bg-brand-dark border border-white/10 rounded-[8px] px-3 py-2
                       text-sm text-white placeholder-white/30
                       focus:outline-none focus:border-brand-lime/60 focus:ring-1 focus:ring-brand-lime/30
                       transition-colors"
              />
            </div>

            <!-- Tel + Email row -->
            <div class="grid sm:grid-cols-2 gap-4">
              <div class="flex flex-col gap-1.5">
                <label for="hero-tel" class="text-xs font-medium text-white/60 uppercase tracking-wide">
                  Phone <span class="text-brand-lime">*</span>
                </label>
                <input
                  id="hero-tel"
                  name="telephone"
                  type="tel"
                  required
                  placeholder="07700 900000"
                  class="w-full bg-brand-dark border border-white/10 rounded-[8px] px-3 py-2
                         text-sm text-white placeholder-white/30
                         focus:outline-none focus:border-brand-lime/60 focus:ring-1 focus:ring-brand-lime/30
                         transition-colors"
                />
              </div>
              <div class="flex flex-col gap-1.5">
                <label for="hero-email" class="text-xs font-medium text-white/60 uppercase tracking-wide">
                  Email <span class="text-brand-lime">*</span>
                </label>
                <input
                  id="hero-email"
                  name="email"
                  type="email"
                  required
                  placeholder="you@company.com"
                  class="w-full bg-brand-dark border border-white/10 rounded-[8px] px-3 py-2
                         text-sm text-white placeholder-white/30
                         focus:outline-none focus:border-brand-lime/60 focus:ring-1 focus:ring-brand-lime/30
                         transition-colors"
                />
              </div>
            </div>

            <!-- Description -->
            <div class="flex flex-col gap-1.5">
              <label for="hero-desc" class="text-xs font-medium text-white/60 uppercase tracking-wide">
                Description <span class="text-brand-lime">*</span>
              </label>
              <textarea
                id="hero-desc"
                name="description"
                required
                rows="3"
                placeholder="Tell us about your waste management needs…"
                class="w-full bg-brand-dark border border-white/10 rounded-[8px] px-3 py-2
                       text-sm text-white placeholder-white/30 resize-none
                       focus:outline-none focus:border-brand-lime/60 focus:ring-1 focus:ring-brand-lime/30
                       transition-colors"
              ></textarea>
            </div>

            <!-- Submit -->
            <button
              type="submit"
              class="w-full inline-flex items-center justify-center gap-2 bg-brand-forest text-white
                     px-6 py-2.5 rounded-[8px] text-sm font-semibold
                     hover:bg-brand-forest-dark hover:-translate-y-0.5 hover:shadow-cta
                     transition-all duration-200 mt-1"
            >
              Send Enquiry
              <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/>
              </svg>
            </button>

          </form>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  const input     = document.getElementById('hero-images') as HTMLInputElement;
  const label     = document.getElementById('drop-label')!;
  const dropZone  = document.getElementById('drop-zone')!;

  input.addEventListener('change', () => {
    const count = input.files?.length ?? 0;
    label.textContent = count === 0
      ? 'Click to upload or drag & drop'
      : count === 1
        ? input.files![0].name
        : `${count} images selected`;
  });

  dropZone.addEventListener('dragover', (e) => {
    e.preventDefault();
    dropZone.classList.add('border-brand-lime/50', 'bg-brand-lime/5');
  });

  dropZone.addEventListener('dragleave', () => {
    dropZone.classList.remove('border-brand-lime/50', 'bg-brand-lime/5');
  });

  dropZone.addEventListener('drop', (e) => {
    e.preventDefault();
    dropZone.classList.remove('border-brand-lime/50', 'bg-brand-lime/5');
    if (e.dataTransfer?.files.length) {
      const dt = new DataTransfer();
      Array.from(e.dataTransfer.files)
        .filter(f => f.type.startsWith('image/'))
        .forEach(f => dt.items.add(f));
      input.files = dt.files;
      input.dispatchEvent(new Event('change'));
    }
  });
</script>
