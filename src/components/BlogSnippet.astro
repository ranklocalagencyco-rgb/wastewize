---
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

function fmtDate(d: Date) {
  return d.toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' });
}
---

{posts.length > 0 && (
  <section class="bg-brand-dark border-t border-white/8 py-14 sm:py-16"
           aria-labelledby="blog-snippet-heading">
    <div class="container mx-auto px-4 sm:px-6">

      <div class="flex items-end justify-between mb-8 gap-4">
        <div>
          <p class="text-xs font-semibold tracking-widest uppercase text-brand-lime mb-1">
            From the blog
          </p>
          <h2 id="blog-snippet-heading"
              class="text-xl sm:text-2xl font-display font-bold text-white leading-tight">
            Don't Get Caught Out
          </h2>
        </div>
        <a href="/blog"
           class="shrink-0 text-sm font-semibold text-brand-lime hover:text-white
                  transition-colors underline underline-offset-4">
          All articles →
        </a>
      </div>

      <ul class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {posts.map((post) => (
          <li>
            <a href={`/blog/${post.id}`}
               class="flex flex-col h-full bg-brand-dark-card border border-white/8
                      rounded-[14px] p-5 hover:border-brand-lime/40
                      hover:-translate-y-0.5 transition-all duration-200 group">
              <div class="flex items-center gap-2 mb-3">
                <span class="text-[10px] font-semibold tracking-widest uppercase
                             text-brand-lime bg-brand-lime/10 px-2.5 py-1 rounded-full">
                  {post.data.category}
                </span>
                <time datetime={post.data.date.toISOString()}
                      class="text-[11px] text-white/40 ml-auto">
                  {fmtDate(post.data.date)}
                </time>
              </div>
              <h3 class="text-sm font-semibold text-white leading-snug mb-2
                         group-hover:text-brand-lime transition-colors line-clamp-3">
                {post.data.title}
              </h3>
              <p class="text-xs text-white/50 leading-relaxed line-clamp-2 mt-auto pt-2">
                {post.data.description}
              </p>
            </a>
          </li>
        ))}
      </ul>

    </div>
  </section>
)}
