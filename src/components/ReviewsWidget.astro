---
// src/components/ReviewsWidget.astro
---
<section class="bg-brand-dark border-b border-white/8 py-8">
  <div class="container mx-auto px-4">
    <div id="tagembed-root" class="tagembed-widget" style="width:100%;height:100%;overflow:auto;" data-widget-id="327508" data-website="1"></div>
  </div>
</section>

<script is:inline>
  (function () {
    var loaded = false;
    function loadWidget() {
      if (loaded) return;
      loaded = true;
      var s = document.createElement('script');
      s.src = 'https://widget.tagembed.com/embed.min.js';
      s.type = 'text/javascript';
      s.async = true;
      document.head.appendChild(s);
    }
    var root = document.getElementById('tagembed-root');
    if (root && 'IntersectionObserver' in window) {
      var io = new IntersectionObserver(function (entries, obs) {
        if (entries[0].isIntersecting) { loadWidget(); obs.disconnect(); }
      }, { rootMargin: '300px' });
      io.observe(root);
    } else {
      window.addEventListener('load', loadWidget);
    }
  })();
</script>
