---

<section class="bg-brand-dark border-b border-white/8 py-14 sm:py-16 overflow-hidden">
  <div class="container mx-auto px-4 sm:px-6 mb-8">
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
      <div class="flex items-center gap-3">
        <!-- Google G -->
        <svg class="w-8 h-8 shrink-0" viewBox="0 0 24 24" aria-hidden="true">
          <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
          <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
          <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z"/>
          <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
        </svg>
        <div>
          <p class="text-sm font-semibold text-white">Google Reviews</p>
          <div class="flex items-center gap-2 mt-0.5">
            <div class="flex" aria-label="5 out of 5 stars">
              {Array(5).fill(null).map(() => (
                <svg class="w-4 h-4 text-[#FBBC05]" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                </svg>
              ))}
            </div>
            <span class="text-xs text-white/50">4.9 average · 17 reviews</span>
          </div>
        </div>
      </div>
      <a
        href="https://www.google.com/maps/place/WasteWize+UK"
        target="_blank"
        rel="noopener noreferrer"
        class="self-start sm:self-auto inline-flex items-center gap-1.5 text-xs font-semibold text-brand-lime border border-brand-lime/30 rounded-full px-4 py-1.5 hover:bg-brand-lime/10 transition-colors"
      >
        See all on Google
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/>
        </svg>
      </a>
    </div>
  </div>

  <!-- Marquee track — duplicated for seamless loop -->
  <div class="reviews-outer" aria-label="Customer reviews carousel">
    <div class="reviews-track">
      {[...reviews, ...reviews].map((r, i) => (
        <article
          class="reviews-card bg-brand-dark-card border border-white/8 rounded-[12px] p-5 flex flex-col gap-3"
          aria-hidden={i >= reviews.length ? 'true' : undefined}
        >
          <div class="flex items-center gap-3">
            <div class="w-9 h-9 rounded-full bg-brand-lime/15 flex items-center justify-center shrink-0">
              <span class="text-xs font-bold text-brand-lime">{r.initials}</span>
            </div>
            <div class="min-w-0">
              <p class="text-sm font-semibold text-white leading-tight">{r.name}</p>
              <p class="text-[11px] text-white/40">{r.date}</p>
            </div>
            <div class="ml-auto flex shrink-0" aria-label="5 stars">
              {Array(5).fill(null).map(() => (
                <svg class="w-3.5 h-3.5 text-[#FBBC05]" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                </svg>
              ))}
            </div>
          </div>
          <p class="text-sm text-white/60 leading-relaxed">{r.text}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .reviews-outer {
    overflow: hidden;
    /* fade edges */
    mask-image: linear-gradient(to right, transparent 0%, black 6%, black 94%, transparent 100%);
    -webkit-mask-image: linear-gradient(to right, transparent 0%, black 6%, black 94%, transparent 100%);
  }

  .reviews-track {
    display: flex;
    gap: 1rem;
    width: max-content;
    animation: reviews-scroll 55s linear infinite;
  }

  .reviews-track:hover {
    animation-play-state: paused;
  }

  .reviews-card {
    width: 300px;
    flex-shrink: 0;
  }

  @media (min-width: 640px) {
    .reviews-card {
      width: 340px;
    }
  }

  @keyframes reviews-scroll {
    0%   { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }

  @media (prefers-reduced-motion: reduce) {
    .reviews-track {
      animation: none;
      flex-wrap: wrap;
    }
  }
</style>
