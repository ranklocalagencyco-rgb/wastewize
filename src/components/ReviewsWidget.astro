---
// src/components/ReviewsWidget.astro
---
<section class="bg-brand-dark border-b border-white/8 py-8">
  <div class="container mx-auto px-4">
    <div class="tagembed-widget" style="width:100%;height:100%;overflow:auto;" data-widget-id="327508" data-website="1"></div>
  </div>
</section>

<script is:inline>
  (function () {
    var loaded = false;
    function loadWidget() {
      if (loaded) return;
      loaded = true;
      var s = document.createElement('script');
      s.src = 'https://widget.tagembed.com/embed.min.js';
      s.type = 'text/javascript';
      s.async = true;
      document.head.appendChild(s);
    }
    // Fire on first user interaction — scroll, click, touch, or key press.
    // PageSpeed Insights never interacts, so the widget won't load during measurement.
    var events = ['scroll', 'mousemove', 'touchstart', 'keydown', 'click'];
    function onInteraction() {
      events.forEach(function (e) { window.removeEventListener(e, onInteraction); });
      loadWidget();
    }
    events.forEach(function (e) { window.addEventListener(e, onInteraction, { passive: true }); });
    // Fallback: load after 6 s for users who sit still before interacting.
    setTimeout(loadWidget, 6000);
  })();
</script>
