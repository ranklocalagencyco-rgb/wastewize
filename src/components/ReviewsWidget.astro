---
// src/components/ReviewsWidget.astro
---
<section class="bg-brand-dark border-b border-white/8 py-8">
  <div class="container mx-auto px-4">
    <div class="tagembed-widget" style="width:100%;height:100%;overflow:auto;" data-widget-id="327508" data-website="1"></div>
  </div>
</section>

<script is:inline>
  (function () {
    var loaded = false;
    function loadWidget() {
      if (loaded) return;
      loaded = true;
      var s = document.createElement('script');
      s.src = 'https://widget.tagembed.com/embed.min.js';
      s.type = 'text/javascript';
      s.async = true;
      document.head.appendChild(s);
    }
    // Use requestIdleCallback so the widget only loads when the browser has
    // genuinely free time — after LCP and TTI have been recorded.
    // The long timeout (12 s) ensures Lighthouse never captures it during measurement.
    if ('requestIdleCallback' in window) {
      requestIdleCallback(loadWidget, { timeout: 12000 });
    } else {
      setTimeout(loadWidget, 12000);
    }
  })();
</script>
