---
// src/components/ServiceCard.astro
// Reusable service tile. Used inside ServicesGrid.astro.

interface Props {
  title:     string;
  shortDesc: string;
  href:      string;
  icon:      string;
}

const { title, shortDesc, href, icon } = Astro.props;
---

<a
  href={href}
  class="group bg-brand-dark-card rounded-[12px] border border-white/10 p-8
         hover:border-brand-lime/40 hover:shadow-card
         hover:-translate-y-1 transition-all duration-300 flex flex-col gap-5"
>
  <!-- Icon bubble -->
  <div
    class="w-14 h-14 rounded-[10px] bg-brand-lime/10 flex items-center justify-center
           group-hover:bg-brand-lime/20 transition-colors shrink-0"
    aria-hidden="true"
  >
    <svg
      class="w-7 h-7 text-brand-lime group-hover:text-white transition-colors"
      fill="none"
      stroke="currentColor"
      stroke-width="1.7"
      viewBox="0 0 24 24"
      aria-hidden="true"
    >
      <path stroke-linecap="round" stroke-linejoin="round" d={icon}/>
    </svg>
  </div>

  <!-- Content -->
  <div class="flex flex-col gap-3 flex-1">
    <h3 class="text-lg font-semibold text-white group-hover:text-brand-lime
               transition-colors leading-snug">
      {title}
    </h3>
    <p class="text-sm leading-relaxed text-white/60 flex-1">
      {shortDesc}
    </p>
  </div>

</a>
