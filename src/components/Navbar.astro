---
const navLinks = [
  { label: 'Home',           href: '/' },
  { label: 'Services',       href: '/services' },
  { label: 'Prices',         href: '/prices' },
  { label: 'Areas',          href: '/areas' },
  { label: 'Sustainability', href: '/sustainability' },
  { label: 'About Us',       href: '/about' },
  { label: 'Blog',           href: '/blog' },
  { label: 'Contact',        href: '/contact' },
];
---

<header
  id="main-nav"
  class="sticky top-0 z-50 bg-brand-dark/95 backdrop-blur-sm border-b border-white/8 shadow-[0_2px_20px_rgba(0,0,0,0.4)]"
>
  <div class="container mx-auto flex items-center justify-between gap-6 h-20 px-4">

    <!-- ── Logo ── -->
    <a href="/" class="flex items-center gap-2.5 shrink-0" aria-label="WasteWize UK home">
      <img src="/Wastewize-logo.webp" alt="WasteWize London & Home Counties — Licensed Waste Removal" class="h-12 w-auto object-contain" width="47" height="48" />
      <div class="leading-none">
        <span class="block font-body font-semibold text-[17px] tracking-tight text-white">
          <span class="text-brand-lime">Waste</span>Wize
        </span>
        <span class="block text-[9px] font-semibold tracking-[0.12em] uppercase text-white/60 mt-0.5">
          London &amp; Home Counties
        </span>
      </div>
    </a>

    <!-- ── Desktop nav links ── -->
    <nav class="hidden lg:flex items-center gap-1" aria-label="Main navigation">

      {navLinks.map(({ label, href }) => (
        <a
          href={href}
          class="relative px-3.5 py-2 text-[14px] font-medium text-white/70 hover:text-brand-lime
                 transition-colors group rounded-[6px] hover:bg-white/5"
        >
          {label}
          <span
            class="absolute bottom-1 left-3.5 right-3.5 h-[2px] rounded-full bg-brand-lime
                   scale-x-0 group-hover:scale-x-100 transition-transform origin-left"
            aria-hidden="true"
          />
        </a>
      ))}
    </nav>

    <!-- ── CTA + Hamburger ── -->
    <div class="flex items-center gap-3 shrink-0">

      <!-- Desktop CTA -->
      <a
        href="/contact#quote"
        class="hidden lg:inline-flex items-center gap-2 bg-brand-forest text-white
               px-5 py-2.5 rounded-[8px] text-sm font-semibold
               hover:bg-brand-forest-dark hover:-translate-y-px hover:shadow-cta
               transition-all duration-200 focus-visible:outline focus-visible:outline-2
               focus-visible:outline-brand-lime focus-visible:outline-offset-2"
      >
        Get a Quote
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/>
        </svg>
      </a>

      <!-- Mobile hamburger -->
      <button
        id="hamburger-btn"
        type="button"
        class="lg:hidden flex flex-col justify-center items-center w-10 h-10 rounded-[8px]
               border border-white/15 hover:border-brand-lime hover:bg-white/5
               transition-colors gap-[5px] p-2.5"
        aria-controls="mobile-menu"
        aria-expanded="false"
        aria-label="Toggle navigation menu"
      >
        <span id="ham-1" class="block w-full h-[2px] bg-white/70 rounded-full transition-all duration-300"/>
        <span id="ham-2" class="block w-full h-[2px] bg-white/70 rounded-full transition-all duration-300"/>
        <span id="ham-3" class="block w-full h-[2px] bg-white/70 rounded-full transition-all duration-300"/>
      </button>

    </div>
  </div>

  <!-- ── Mobile menu drawer ── -->
  <div
    id="mobile-menu"
    class="lg:hidden hidden border-t border-white/10 bg-brand-dark-card"
    aria-hidden="true"
  >
    <nav class="container mx-auto px-4 py-4 flex flex-col gap-1" aria-label="Mobile navigation">

      {navLinks.map(({ label, href }) => (
        <a
          href={href}
          class="flex items-center justify-between px-4 py-3 rounded-[8px] text-[15px]
                 font-medium text-white/70 hover:text-white hover:bg-white/5
                 transition-colors border-b border-white/6 last:border-0"
        >
          {label}
          <svg class="w-4 h-4 text-brand-lime" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
          </svg>
        </a>
      ))}

      <!-- Mobile CTA -->
      <a
        href="/contact#quote"
        class="mt-3 flex items-center justify-center gap-2 bg-brand-forest text-white
               px-5 py-3.5 rounded-[8px] text-[15px] font-semibold hover:bg-brand-forest-dark
               transition-colors"
      >
        Get a Free Quote
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/>
        </svg>
      </a>
    </nav>
  </div>
</header>

<script>
  // ── Hamburger ──
  const btn   = document.getElementById('hamburger-btn')!;
  const menu  = document.getElementById('mobile-menu')!;
  const ham1  = document.getElementById('ham-1')!;
  const ham2  = document.getElementById('ham-2')!;
  const ham3  = document.getElementById('ham-3')!;
  let open    = false;

  btn.addEventListener('click', () => {
    open = !open;
    btn.setAttribute('aria-expanded', String(open));
    menu.setAttribute('aria-hidden', String(!open));
    menu.classList.toggle('hidden', !open);

    if (open) {
      ham1.style.transform = 'translateY(7px) rotate(45deg)';
      ham2.style.opacity   = '0';
      ham3.style.transform = 'translateY(-7px) rotate(-45deg)';
    } else {
      ham1.style.transform = '';
      ham2.style.opacity   = '';
      ham3.style.transform = '';
    }
  });

  document.addEventListener('click', (e) => {
    if (open && !btn.contains(e.target as Node) && !menu.contains(e.target as Node)) {
      btn.click();
    }
  });
</script>
