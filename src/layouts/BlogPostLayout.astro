---
import Layout from './Layout.astro';

interface Props {
  title:       string;
  description: string;
  date:        Date;
  category:    string;
  tags?:       string[];
  author?:     string;
  pageTitle?:  string;
  slug:        string;
  faqSchema?:  { question: string; answer: string }[];
}

const {
  title,
  description,
  date,
  category,
  tags,
  author     = 'WasteWize Team',
  pageTitle,
  slug,
  faqSchema,
} = Astro.props;

const BASE        = 'https://wastewize.co.uk';
const pageUrl     = `${BASE}/blog/${slug}`;
const dateDisplay = date.toLocaleDateString('en-GB', {
  day: 'numeric', month: 'long', year: 'numeric',
});
const categorySlug = category.toLowerCase().replace(/\s+/g, '-');

const blogPostingSchema = {
  '@context':      'https://schema.org',
  '@type':         'BlogPosting',
  'headline':      title,
  'description':   description,
  'datePublished': date.toISOString(),
  'dateModified':  date.toISOString(),
  'url':           pageUrl,
  'inLanguage':    'en-GB',
  'author': {
    '@type': 'Person',
    'name':  author,
  },
  'publisher': {
    '@type': 'Organization',
    'name':  'WasteWize UK',
    'url':   BASE,
    'logo': {
      '@type': 'ImageObject',
      'url':   `${BASE}/wastewizeuk-favicon.png`,
    },
  },
};

const faqPageSchema = faqSchema?.length
  ? {
      '@context':   'https://schema.org',
      '@type':      'FAQPage',
      'mainEntity': faqSchema.map(({ question, answer }) => ({
        '@type': 'Question',
        'name':  question,
        'acceptedAnswer': { '@type': 'Answer', 'text': answer },
      })),
    }
  : null;
---

<Layout title={pageTitle ?? `${title} | WasteWize Blog`} description={description}>

  <Fragment slot="head">
    <script type="application/ld+json" is:inline set:html={JSON.stringify(blogPostingSchema)} />
    {faqPageSchema && (
      <script type="application/ld+json" is:inline set:html={JSON.stringify(faqPageSchema)} />
    )}
  </Fragment>

  <!-- ── Breadcrumb ── -->
  <nav class="bg-brand-dark border-b border-white/5 py-3 px-4" aria-label="Breadcrumb">
    <div class="container mx-auto">
      <ol class="flex flex-wrap items-center gap-1.5 text-xs text-white/40">
        <li><a href="/"     class="hover:text-brand-lime transition-colors">Home</a></li>
        <li aria-hidden="true" class="text-white/20">/</li>
        <li><a href="/blog" class="hover:text-brand-lime transition-colors">Blog</a></li>
        <li aria-hidden="true" class="text-white/20">/</li>
        <li class="text-white/70 truncate max-w-[220px] sm:max-w-sm" aria-current="page">{title}</li>
      </ol>
    </div>
  </nav>

  <!-- ── Hero ── -->
  <section class="bg-brand-dark border-b border-white/8 py-14 sm:py-20">
    <div class="container mx-auto px-4 sm:px-6 max-w-5xl">
      <div class="flex flex-wrap items-center gap-3 mb-6">
        <a href={`/blog#${categorySlug}`}
           class="inline-flex items-center text-xs font-semibold tracking-widest uppercase
                  text-brand-lime bg-brand-lime/10 border border-brand-lime/30
                  rounded-full px-3 py-1 hover:bg-brand-lime/20 transition-colors">
          {category}
        </a>
        <time datetime={date.toISOString()} class="text-sm text-white/40">{dateDisplay}</time>
        <span class="text-white/20" aria-hidden="true">·</span>
        <span class="text-sm text-white/40">{author}</span>
      </div>
      <h1 class="font-display text-3xl sm:text-4xl lg:text-5xl font-extrabold text-white
                 leading-tight max-w-3xl mb-5">
        {title}
      </h1>
      <p class="text-base sm:text-lg text-white/60 max-w-2xl leading-relaxed">{description}</p>
    </div>
  </section>

  <!-- ── Two-column body ── -->
  <div class="bg-gray-50 py-12 sm:py-16">
    <div class="container mx-auto px-4 sm:px-6 max-w-5xl">
      <div class="flex flex-col lg:flex-row gap-10 lg:gap-12 items-start">

        <!-- Article -->
        <article class="flex-1 min-w-0 bg-white rounded-xl shadow-sm px-8 py-10 sm:px-12">
          <div class="prose-blog">
            <slot />
          </div>

          <!-- Tags -->
          {tags && tags.length > 0 && (
            <div class="mt-10 pt-6 border-t border-gray-100">
              <p class="text-xs font-bold uppercase tracking-wider text-brand-slate mb-3">Tags</p>
              <div class="flex flex-wrap gap-2">
                {tags.map((tag) => (
                  <span class="text-xs bg-gray-100 text-brand-slate rounded-full px-3 py-1">
                    {tag}
                  </span>
                ))}
              </div>
            </div>
          )}

          <!-- Share -->
          <div class="mt-8 pt-6 border-t border-gray-100">
            <p class="text-xs font-bold uppercase tracking-wider text-brand-slate mb-3">Share this guide</p>
            <div class="flex flex-wrap gap-2">
              <a href={`https://twitter.com/intent/tweet?text=${encodeURIComponent(title)}&url=${encodeURIComponent(pageUrl)}`}
                 target="_blank" rel="noopener noreferrer"
                 class="inline-flex items-center gap-1.5 text-xs font-semibold px-3 py-1.5
                        bg-black text-white rounded-full hover:opacity-80 transition-opacity">
                <svg class="w-3.5 h-3.5 shrink-0" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.744l7.737-8.835L1.254 2.25H8.08l4.253 5.622 5.911-5.622Zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
                </svg>
                X / Twitter
              </a>
              <a href={`https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(pageUrl)}`}
                 target="_blank" rel="noopener noreferrer"
                 class="inline-flex items-center gap-1.5 text-xs font-semibold px-3 py-1.5
                        bg-[#1877F2] text-white rounded-full hover:opacity-80 transition-opacity">
                <svg class="w-3.5 h-3.5 shrink-0" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
                </svg>
                Facebook
              </a>
              <a href={`https://www.linkedin.com/shareArticle?mini=true&url=${encodeURIComponent(pageUrl)}&title=${encodeURIComponent(title)}`}
                 target="_blank" rel="noopener noreferrer"
                 class="inline-flex items-center gap-1.5 text-xs font-semibold px-3 py-1.5
                        bg-[#0A66C2] text-white rounded-full hover:opacity-80 transition-opacity">
                <svg class="w-3.5 h-3.5 shrink-0" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
                </svg>
                LinkedIn
              </a>
              <a href={`https://wa.me/?text=${encodeURIComponent(title + ' — ' + pageUrl)}`}
                 target="_blank" rel="noopener noreferrer"
                 class="inline-flex items-center gap-1.5 text-xs font-semibold px-3 py-1.5
                        bg-[#25D366] text-white rounded-full hover:opacity-80 transition-opacity">
                <svg class="w-3.5 h-3.5 shrink-0" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
                </svg>
                WhatsApp
              </a>
              <button id="copy-link-btn" data-url={pageUrl}
                      class="inline-flex items-center gap-1.5 text-xs font-semibold px-3 py-1.5
                             bg-gray-100 text-brand-slate rounded-full hover:bg-gray-200
                             transition-colors cursor-pointer border-0">
                <svg class="w-3.5 h-3.5 shrink-0" fill="none" stroke="currentColor" stroke-width="2"
                     viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round"
                        d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"/>
                </svg>
                <span id="copy-link-label">Copy link</span>
              </button>
            </div>
          </div>

          <!-- Was this helpful? -->
          <div class="mt-8 p-5 bg-brand-lime-pale border border-brand-lime-light rounded-xl">
            <p class="text-sm font-semibold text-brand-slate mb-1">Was this guide helpful?</p>
            <p class="text-xs text-brand-slate leading-relaxed">
              We publish free waste management guides for homeowners and businesses across
              London and the Home Counties.{' '}
              <a href="/blog" class="text-brand-forest underline hover:text-brand-lime transition-colors">
                Browse all guides →
              </a>
            </p>
          </div>

          <!-- Author byline -->
          <p class="mt-6 text-xs text-brand-slate/60 leading-relaxed">
            Written by <span class="font-semibold text-brand-slate">{author}</span>
            {' · '}WasteWize London &amp; Home Counties
            {' · '}Environment Agency Registered Waste Carrier
            {' · '}SafeContractor Accredited
          </p>
        </article>

        <!-- Right rail -->
        <aside class="w-full lg:w-72 shrink-0 flex flex-col gap-6 lg:sticky lg:top-6">

          <!-- CTA card -->
          <div class="bg-brand-forest rounded-xl p-6 text-white">
            <p class="text-xs font-bold uppercase tracking-widest text-white/60 mb-2">
              Need Waste Removed?
            </p>
            <p class="text-lg font-bold leading-tight mb-2">Get a Free Quote</p>
            <p class="text-sm text-white/75 leading-relaxed mb-5">
              Same-day availability across London &amp; the Home Counties.
              EA Licence CBDU335711.
            </p>
            <a href="tel:+447929771954"
               class="flex items-center gap-2 text-sm font-semibold text-white mb-4
                      hover:text-brand-lime transition-colors">
              <svg class="w-4 h-4 shrink-0" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                <path d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z"/>
              </svg>
              07929 771954
            </a>
            <a href="/contact#quote"
               class="block w-full text-center bg-white text-brand-forest px-4 py-2.5
                      rounded-lg text-sm font-bold hover:bg-brand-lime hover:text-brand-dark
                      transition-colors duration-200">
              Request a Callback
            </a>
          </div>

          <!-- Related services slot -->
          <div class="bg-white border border-gray-200 rounded-xl p-6 shadow-sm">
            <p class="text-xs font-bold text-brand-slate uppercase tracking-wider mb-4">
              Related Services
            </p>
            <slot name="related-services">
              <ul class="space-y-2.5">
                <li>
                  <a href="/services/scrap-metal-collection"
                     class="text-sm text-brand-forest underline hover:text-brand-lime transition-colors">
                    Scrap Metal Collection
                  </a>
                </li>
                <li>
                  <a href="/blog/fly-tipping-removal-london"
                     class="text-sm text-brand-forest underline hover:text-brand-lime transition-colors">
                    Fly-Tipping Removal
                  </a>
                </li>
                <li>
                  <a href="/house-clearance"
                     class="text-sm text-brand-forest underline hover:text-brand-lime transition-colors">
                    House Clearance
                  </a>
                </li>
                <li>
                  <a href="/services/builders-waste-removal"
                     class="text-sm text-brand-forest underline hover:text-brand-lime transition-colors">
                    Builders' Waste Removal
                  </a>
                </li>
                <li>
                  <a href="/office-clearance"
                     class="text-sm text-brand-forest underline hover:text-brand-lime transition-colors">
                    Office Clearance
                  </a>
                </li>
              </ul>
            </slot>
          </div>

        </aside>
      </div>
    </div>
  </div>

  <script>
    const btn   = document.getElementById('copy-link-btn');
    const label = document.getElementById('copy-link-label');
    if (btn && label) {
      btn.addEventListener('click', async () => {
        const url = (btn as HTMLElement).dataset.url ?? window.location.href;
        try {
          await navigator.clipboard.writeText(url);
          label.textContent = 'Copied!';
          setTimeout(() => { label.textContent = 'Copy link'; }, 2000);
        } catch {
          label.textContent = 'Copy failed';
          setTimeout(() => { label.textContent = 'Copy link'; }, 2000);
        }
      });
    }
  </script>

</Layout>

<style>
  .prose-blog :global(h2) {
    color: #2e7d32;
    font-weight: 700;
    font-size: 1.5rem;
    line-height: 1.3;
    margin-top: 2.5rem;
    margin-bottom: 1rem;
  }
  .prose-blog :global(h3) {
    color: #37474f;
    font-weight: 600;
    font-size: 1.25rem;
    line-height: 1.4;
    margin-top: 2rem;
    margin-bottom: 0.75rem;
  }
  .prose-blog :global(p) {
    color: #37474f;
    line-height: 1.75;
    margin-bottom: 1rem;
  }
  .prose-blog :global(a) {
    color: #2e7d32;
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .prose-blog :global(a:hover) {
    color: #8bc34a;
  }
  .prose-blog :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin-bottom: 1.5rem;
    font-size: 0.875rem;
  }
  .prose-blog :global(th) {
    background-color: #f3f4f6;
    padding: 0.625rem 1rem;
    text-align: left;
    font-weight: 600;
    color: #37474f;
    border-bottom: 2px solid #e5e7eb;
  }
  .prose-blog :global(td) {
    padding: 0.625rem 1rem;
    border-bottom: 1px solid #e5e7eb;
    color: #37474f;
  }
  .prose-blog :global(ul) {
    list-style-type: disc;
    padding-left: 1.5rem;
    margin-bottom: 1rem;
  }
  .prose-blog :global(ol) {
    list-style-type: decimal;
    padding-left: 1.5rem;
    margin-bottom: 1rem;
  }
  .prose-blog :global(li) {
    color: #37474f;
    margin-bottom: 0.25rem;
    line-height: 1.6;
  }
  .prose-blog :global(strong) {
    font-weight: 600;
    color: #37474f;
  }
  .prose-blog :global(blockquote) {
    border-left: 4px solid #8bc34a;
    padding-left: 1rem;
    margin: 1.5rem 0;
    color: #546e7a;
    font-style: italic;
  }
  .prose-blog :global(code) {
    background-color: #f3f4f6;
    padding: 0.125rem 0.375rem;
    border-radius: 0.25rem;
    font-size: 0.875em;
    color: #37474f;
  }
  .prose-blog :global(hr) {
    border-color: #e5e7eb;
    margin: 2rem 0;
  }
</style>
