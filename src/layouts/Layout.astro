---
import TopBar    from '../components/TopBar.astro';
import Navbar    from '../components/Navbar.astro';
import Footer    from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title?:       string;
  description?: string;
  ogImage?:     string;
}

const {
  title       = 'WasteWize UK | Waste Removal for Homeowners & Businesses — London & Home Counties',
  description = 'EA-licensed waste removal for homeowners and businesses. 99% landfill diversion rate. House clearances, commercial collections & more across London & the Home Counties. Get a free quote today.',
  ogImage     = '/og-image.jpg',
} = Astro.props;

const GA_ID = 'G-8H4RV4TTPE';
---
<!DOCTYPE html>
<html lang="en-GB" class="scroll-smooth">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <!-- Primary SEO -->
  <title>{title}</title>
  <meta name="description"        content={description} />
  <meta name="robots"             content="index, follow" />
  <link rel="canonical"           href={Astro.url.href} />
  <link rel="sitemap"             href="/sitemap.xml" />

  <!-- Open Graph -->
  <meta property="og:type"        content="website" />
  <meta property="og:site_name"   content="WasteWize UK" />
  <meta property="og:title"       content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url"         content={Astro.url} />
  <meta property="og:image"       content={ogImage} />

  <!-- Twitter / X -->
  <meta name="twitter:card"        content="summary_large_image" />
  <meta name="twitter:site"        content="@wastewizeltd" />
  <meta name="twitter:title"       content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image"       content={ogImage} />

  <!-- Favicons -->
  <link rel="icon"             href="/wastewizeuk-favicon.png" type="image/png" />
  <link rel="apple-touch-icon" href="/wastewizeuk-favicon.png" />
  <meta name="theme-color"      content="#2E7D32" />

  <!-- Self-hosted fonts: preload critical woff2 files -->
  <link rel="preload" href="/fonts/dm-sans-latin.woff2"      as="font" type="font/woff2" crossorigin />
  <link rel="preload" href="/fonts/fraunces-latin.woff2"     as="font" type="font/woff2" crossorigin />

  <!-- Google Analytics 4 — deferred until after page load, off critical path -->
  <script is:inline define:vars={{ GA_ID }}>
    if (GA_ID && GA_ID !== 'G-XXXXXXXXXX') {
      window.addEventListener('load', function () {
        var s = document.createElement('script');
        s.src = 'https://www.googletagmanager.com/gtag/js?id=' + GA_ID;
        s.async = true;
        document.head.appendChild(s);
        window.dataLayer = window.dataLayer || [];
        function gtag() { dataLayer.push(arguments); }
        gtag('js', new Date());
        gtag('config', GA_ID);
      });
    }
  </script>

  <!-- Page-specific head content (JSON-LD, extra meta, etc.) -->
  <slot name="head" />
</head>
<body class="font-body text-white bg-brand-dark antialiased">

  <!-- ① Dual-layer header: TopBar + sticky Navbar -->
  <TopBar />
  <Navbar />

  <!-- ② Page-specific content -->
  <main>
    <slot />
  </main>

  <!-- ③ Footer -->
  <Footer />

  <script is:inline>
    (function () {
      function buildEmails() {
        document.querySelectorAll('[data-user][data-host]').forEach(function (el) {
          var addr = el.dataset.user + '@' + el.dataset.host;
          if (el.tagName === 'A') el.href = 'mailto:' + addr;
          var span = el.querySelector('[data-email-text]');
          if (span) span.textContent = addr;
        });
      }
      'requestIdleCallback' in window ? requestIdleCallback(buildEmails) : setTimeout(buildEmails, 0);
    })();
  </script>

</body>
</html>
