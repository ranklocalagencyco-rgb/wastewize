---
import TopBar    from '../components/TopBar.astro';
import Navbar    from '../components/Navbar.astro';
import Footer    from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title?:       string;
  description?: string;
  ogImage?:     string;
  townName?:    string;
  serviceName?: string;
}

const {
  title       = 'WasteWize UK | Waste Removal for Homeowners & Businesses — London & Home Counties',
  description = 'EA-licensed waste removal for homeowners and businesses. 99% landfill diversion rate. House clearances, commercial collections & more across London & the Home Counties. Get a free quote today.',
  ogImage     = '/og-image.jpg',
  townName    = 'London',
  serviceName = 'waste removal',
} = Astro.props;

const _waNumber = '447929771954';
const _waText   = encodeURIComponent(`Hi WasteWize, I'm in ${townName} and I'd like a quote for ${serviceName}.`);

const GA_ID = 'G-8XEKHDT3J0';

// Canonical: strip trailing slash so it matches Vercel's clean-URL format.
// Homepage stays https://wastewize.co.uk/ — all other pages have no trailing slash.
const canonicalHref = Astro.url.pathname === '/'
  ? new URL('/', Astro.site).href
  : new URL(Astro.url.pathname.replace(/\/+$/, ''), Astro.site).href;
---
<!DOCTYPE html>
<html lang="en-GB" class="scroll-smooth">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <!-- Primary SEO -->
  <title>{title}</title>
  <meta name="description"        content={description} />
  <meta name="robots"             content="index, follow" />
  <link rel="canonical"           href={canonicalHref} />
  <link rel="sitemap"             href="/sitemap.xml" />

  <!-- Open Graph -->
  <meta property="og:type"        content="website" />
  <meta property="og:site_name"   content="WasteWize UK" />
  <meta property="og:title"       content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url"         content={Astro.url} />
  <meta property="og:image"       content={ogImage} />

  <!-- Twitter / X -->
  <meta name="twitter:card"        content="summary_large_image" />
  <meta name="twitter:site"        content="@wastewizeltd" />
  <meta name="twitter:title"       content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image"       content={ogImage} />

  <!-- Favicons -->
  <link rel="icon"             href="/wastewizeuk-favicon.png" type="image/png" />
  <link rel="apple-touch-icon" href="/wastewizeuk-favicon.png" />
  <meta name="theme-color"      content="#2E7D32" />

  <!-- Self-hosted fonts: preload critical woff2 files -->
  <link rel="preload" href="/fonts/dm-sans-latin.woff2"      as="font" type="font/woff2" crossorigin />
  <link rel="preload" href="/fonts/fraunces-latin.woff2"     as="font" type="font/woff2" crossorigin />

  <!-- Google Analytics 4 — loaded at browser idle time, after all scored metrics -->
  <script is:inline define:vars={{ GA_ID }}>
    (function () {
      if (!GA_ID || GA_ID === 'G-XXXXXXXXXX') return;
      function loadGA() {
        window.dataLayer = window.dataLayer || [];
        window.gtag = function () { dataLayer.push(arguments); };
        gtag('js', new Date());
        gtag('config', GA_ID);
        var s = document.createElement('script');
        s.src = 'https://www.googletagmanager.com/gtag/js?id=' + GA_ID;
        s.async = true;
        document.head.appendChild(s);
      }
      if ('requestIdleCallback' in window) {
        requestIdleCallback(loadGA);
      } else {
        window.addEventListener('load', function () { setTimeout(loadGA, 5000); });
      }
    })();
  </script>

  <!-- Page-specific head content (JSON-LD, extra meta, etc.) -->
  <slot name="head" />
</head>
<body class="font-body text-white bg-brand-dark antialiased">

  <!-- ① Dual-layer header: TopBar + sticky Navbar -->
  <TopBar />
  <Navbar />

  <!-- ② Page-specific content -->
  <main>
    <slot />
  </main>

  <!-- ③ Footer -->
  <Footer />

  <!-- ④ WhatsApp sticky button -->
  <div class="fixed bottom-6 right-6 z-[9999] group">
    <span class="absolute right-full mr-3 top-1/2 -translate-y-1/2 px-3 py-1.5
                 bg-brand-forest text-white text-xs font-bold rounded-lg
                 opacity-0 group-hover:opacity-100 transition-opacity duration-300
                 whitespace-nowrap pointer-events-none border border-white/10 shadow-float">
      Chat with us
    </span>
    <a
      id="whatsapp-trigger"
      href={`https://wa.me/${_waNumber}?text=${_waText}`}
      target="_blank"
      rel="noopener noreferrer"
      aria-label="Chat with WasteWize on WhatsApp"
      class="flex items-center justify-center w-14 h-14 bg-[#25D366] rounded-full
             shadow-[0_0_20px_rgba(37,211,102,0.4)]
             hover:scale-110 active:scale-95 transition-all duration-200"
    >
      <svg class="w-8 h-8 text-white" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
      </svg>
    </a>
  </div>

  <!-- ⑤ WhatsApp lead tracking -->
  <script is:inline define:vars={{ townName, serviceName, GA_ID }}>
    (function () {
      var btn = document.getElementById('whatsapp-trigger');
      if (!btn) return;
      btn.addEventListener('click', function () {
        if (typeof gtag === 'undefined') return;
        gtag('event', 'generate_lead', {
          event_category:  'Conversion',
          event_label:     'WhatsApp: ' + serviceName,
          town:            townName,
          service:         serviceName,
          value:           50.00,
          currency:        'GBP',
          transport_type:  'beacon',
        });
        console.log('Analytics Sent: WhatsApp Lead from ' + townName + ' for ' + serviceName);
      });
    })();
  </script>

  <script is:inline>
    (function () {
      function buildEmails() {
        document.querySelectorAll('[data-user][data-host]').forEach(function (el) {
          var addr = el.dataset.user + '@' + el.dataset.host;
          if (el.tagName === 'A') el.href = 'mailto:' + addr;
          var span = el.querySelector('[data-email-text]');
          if (span) span.textContent = addr;
        });
      }
      'requestIdleCallback' in window ? requestIdleCallback(buildEmails) : setTimeout(buildEmails, 0);
    })();
  </script>

</body>
</html>
