---
import Layout from '../layouts/Layout.astro';
import { areas } from '../data/areas';

function slugify(str: string): string {
  return str.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '');
}

const londonAreas   = areas.filter(a => a.region === 'London');
const countiesAreas = areas.filter(a => a.region === 'Home Counties');

const regionIcon = {
  London:        'M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z',
  'Home Counties':'M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7',
};
---

<Layout
  title="Areas We Cover | WasteWize UK — London & Home Counties"
  description="WasteWize UK collects commercial and residential waste across all London boroughs and the Home Counties — Surrey, Kent, Essex, Hertfordshire, Berkshire, Buckinghamshire, and Middlesex. Same-week availability."
>

  <Fragment slot="head">
    <script type="application/ld+json" is:inline>
    {
      "@context": "https://schema.org",
      "@type": "WasteManagementService",
      "name": "WasteWize UK",
      "url": "https://wastewize.co.uk",
      "telephone": "+447929771954",
      "areaServed": [
        {
          "@type": "City",
          "name": "London",
          "containsPlace": [
            { "@type": "AdministrativeArea", "name": "Central London", "description": "City of London, Westminster, Kensington, Chelsea", "identifier": "EC, WC, SW1, W1" },
            { "@type": "AdministrativeArea", "name": "North London",   "description": "Islington, Camden, Hackney, Haringey",              "identifier": "N, NW" },
            { "@type": "AdministrativeArea", "name": "East London",    "description": "Tower Hamlets, Newham, Waltham Forest, Redbridge",  "identifier": "E, IG" },
            { "@type": "AdministrativeArea", "name": "South London",   "description": "Southwark, Lewisham, Greenwich, Bromley",           "identifier": "SE, BR" },
            { "@type": "AdministrativeArea", "name": "West London",    "description": "Hammersmith, Ealing, Hounslow, Richmond",           "identifier": "W, TW" }
          ]
        },
        {
          "@type": "State",
          "name": "Home Counties",
          "containsPlace": [
            { "@type": "AdministrativeArea", "name": "Surrey",           "description": "Guildford, Woking, Sutton, Epsom",                          "identifier": "GU, KT, RH, SM" },
            { "@type": "AdministrativeArea", "name": "Kent",             "description": "Dartford, Sevenoaks, Tonbridge, Maidstone",                 "identifier": "DA, TN, ME" },
            { "@type": "AdministrativeArea", "name": "Essex",            "description": "Romford, Basildon, Chelmsford, Brentwood",                  "identifier": "RM, SS, CM" },
            { "@type": "AdministrativeArea", "name": "Hertfordshire",    "description": "Watford, St Albans, Hemel Hempstead, Stevenage",            "identifier": "WD, AL, HP, SG" },
            { "@type": "AdministrativeArea", "name": "Berkshire",        "description": "Reading, Slough, Windsor, Maidenhead",                      "identifier": "RG, SL" },
            { "@type": "AdministrativeArea", "name": "Buckinghamshire",  "description": "High Wycombe, Aylesbury, Milton Keynes, Amersham",          "identifier": "HP, MK, LU" },
            { "@type": "AdministrativeArea", "name": "Middlesex",        "description": "Uxbridge, Staines, Feltham, Twickenham",                    "identifier": "UB, TW, HA" }
          ]
        }
      ],
      "description": "WasteWize UK provides professional waste clearance and commercial waste management across all London boroughs and the Home Counties."
    }
    </script>
    <script type="application/ld+json" is:inline set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home",  "item": "https://wastewize.co.uk/" },
        { "@type": "ListItem", "position": 2, "name": "Areas", "item": "https://wastewize.co.uk/areas" }
      ]
    })} />
  </Fragment>

  <!-- ── Page hero ── -->
  <section class="bg-brand-dark py-12 sm:py-16 lg:py-20 border-b border-white/8">
    <div class="container mx-auto px-4 sm:px-6">
      <div class="max-w-2xl">
        <span class="text-xs font-semibold tracking-widest uppercase text-brand-lime mb-3 block">
          Coverage
        </span>
        <h1 class="font-display text-3xl sm:text-4xl lg:text-5xl font-bold text-white mb-4 leading-tight">
          Areas We Cover
        </h1>
        <p class="text-base sm:text-[17px] leading-relaxed text-white/60 max-w-xl">
          Operating from our London depot, we serve businesses and sites across all London
          boroughs and the surrounding Home Counties — with same-week availability and full
          EA compliance documentation on every job.
        </p>
      </div>

      <!-- Coverage stats — 2-up mobile, 4-up sm+ -->
      <div class="mt-8 grid grid-cols-2 sm:grid-cols-4 gap-5 sm:gap-6 max-w-lg sm:max-w-none">
        {[
          { value: '12',      label: 'Coverage Zones' },
          { value: '500+',    label: 'Active Clients' },
          { value: '99%',     label: 'Landfill Diversion' },
          { value: 'Same Wk', label: 'Availability' },
        ].map(({ value, label }) => (
          <div class="bg-brand-dark-card border border-white/10 rounded-[10px] px-4 py-4 sm:px-6 text-center">
            <p class="text-xl sm:text-2xl font-bold text-brand-lime">{value}</p>
            <p class="text-xs text-white/50 mt-1">{label}</p>
          </div>
        ))}
      </div>
    </div>
  </section>


  <!-- ── London ── -->
  <section class="py-12 sm:py-16 lg:py-20 bg-brand-dark">
    <div class="container mx-auto px-4 sm:px-6">

      <div class="flex items-center gap-3 mb-8 sm:mb-10">
        <div class="w-9 h-9 rounded-[8px] bg-brand-lime/10 flex items-center justify-center shrink-0">
          <svg class="w-5 h-5 text-brand-lime" fill="none" stroke="currentColor" stroke-width="1.7" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d={regionIcon['London']}/>
          </svg>
        </div>
        <div>
          <h2 class="text-lg sm:text-xl font-bold text-white">London</h2>
          <p class="text-xs text-white/40 mt-0.5">All 32 boroughs + City of London</p>
        </div>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-5 gap-5 sm:gap-6">
        {londonAreas.map((area) => (
          <article class="group bg-brand-dark-card border border-white/10 rounded-[12px] p-6 sm:p-8
                          hover:border-brand-lime/40 hover:shadow-card hover:-translate-y-1
                          transition-all duration-300 flex flex-col gap-4">
            <h3 class="text-sm sm:text-[15px] font-semibold text-white group-hover:text-brand-lime transition-colors">
              {area.name}
            </h3>
            <p class="text-xs leading-relaxed text-white/50 flex-1">
              {area.desc}
            </p>
            <div class="flex flex-wrap gap-1.5">
              {area.towns.slice(0, 4).map((town) => (
                <a
                  href={`/areas/${area.slug}/${slugify(town)}`}
                  class="text-[10px] font-medium bg-white/5 border border-white/10 text-white/50 rounded-full px-2 py-0.5
                         hover:border-brand-lime/40 hover:text-white/80 transition-colors"
                >
                  {town}
                </a>
              ))}
              {area.towns.length > 4 && (
                <button
                  data-target={`more-${area.slug}`}
                  data-count={area.towns.length - 4}
                  class="text-[10px] font-medium text-brand-lime/70 hover:text-brand-lime self-center cursor-pointer transition-colors"
                >
                  +{area.towns.length - 4} more
                </button>
              )}
            </div>
            {area.towns.length > 4 && (
              <div id={`more-${area.slug}`} class="hidden flex-wrap gap-1.5">
                {area.towns.slice(4).map((town) => (
                  <a
                    href={`/areas/${area.slug}/${slugify(town)}`}
                    class="text-[10px] font-medium bg-white/5 border border-white/10 text-white/50 rounded-full px-2 py-0.5
                           hover:border-brand-lime/40 hover:text-white/80 transition-colors"
                  >
                    {town}
                  </a>
                ))}
              </div>
            )}
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ── Home Counties ── -->
  <section class="py-12 sm:py-16 lg:py-20 bg-brand-dark border-t border-white/8">
    <div class="container mx-auto px-4 sm:px-6">

      <div class="flex items-start gap-3 mb-8 sm:mb-10">
        <div class="w-9 h-9 rounded-[8px] bg-brand-lime/10 flex items-center justify-center shrink-0 mt-0.5">
          <svg class="w-5 h-5 text-brand-lime" fill="none" stroke="currentColor" stroke-width="1.7" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d={regionIcon['Home Counties']}/>
          </svg>
        </div>
        <div>
          <h2 class="text-lg sm:text-xl font-bold text-white">Home Counties</h2>
          <p class="text-xs text-white/40 mt-1 leading-relaxed">
            Surrey · Kent · Essex · Hertfordshire<br class="sm:hidden"/>
            <span class="hidden sm:inline"> · </span>Berkshire · Buckinghamshire · Middlesex
          </p>
        </div>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-5 sm:gap-6">
        {countiesAreas.map((area) => (
          <article class="group bg-brand-dark-card border border-white/10 rounded-[12px] p-6 sm:p-8
                          hover:border-brand-lime/40 hover:shadow-card hover:-translate-y-1
                          transition-all duration-300 flex flex-col gap-4">
            <h3 class="text-sm sm:text-[15px] font-semibold text-white group-hover:text-brand-lime transition-colors">
              {area.name}
            </h3>
            <p class="text-xs leading-relaxed text-white/50 flex-1">
              {area.desc}
            </p>
            <div class="flex flex-wrap gap-1.5">
              {area.towns.slice(0, 4).map((town) => (
                <a
                  href={`/areas/${area.slug}/${slugify(town)}`}
                  class="text-[10px] font-medium bg-white/5 border border-white/10 text-white/50 rounded-full px-2 py-0.5
                         hover:border-brand-lime/40 hover:text-white/80 transition-colors"
                >
                  {town}
                </a>
              ))}
              {area.towns.length > 4 && (
                <button
                  data-target={`more-${area.slug}`}
                  data-count={area.towns.length - 4}
                  class="text-[10px] font-medium text-brand-lime/70 hover:text-brand-lime self-center cursor-pointer transition-colors"
                >
                  +{area.towns.length - 4} more
                </button>
              )}
            </div>
            {area.towns.length > 4 && (
              <div id={`more-${area.slug}`} class="hidden flex-wrap gap-1.5">
                {area.towns.slice(4).map((town) => (
                  <a
                    href={`/areas/${area.slug}/${slugify(town)}`}
                    class="text-[10px] font-medium bg-white/5 border border-white/10 text-white/50 rounded-full px-2 py-0.5
                           hover:border-brand-lime/40 hover:text-white/80 transition-colors"
                  >
                    {town}
                  </a>
                ))}
              </div>
            )}
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ── CTA banner ── -->
  <section class="py-12 sm:py-16 lg:py-20 bg-brand-dark border-t border-white/8">
    <div class="container mx-auto px-4 sm:px-6">
      <div class="bg-brand-dark-card border border-white/10 rounded-[16px] p-6 sm:p-10 lg:p-12">

        <div class="flex flex-col lg:flex-row lg:items-center lg:justify-between gap-6 lg:gap-10">

          <!-- Text -->
          <div>
            <h2 class="font-display text-2xl sm:text-3xl font-bold text-white mb-3">
              Not sure if we cover your area?
            </h2>
            <p class="text-sm sm:text-base text-white/60 leading-relaxed max-w-lg">
              We regularly expand our coverage and often take jobs outside our listed zones.
              Get in touch — chances are we can help.
            </p>
          </div>

          <!-- Buttons -->
          <div class="flex flex-col sm:flex-row items-start gap-3 lg:shrink-0">
            <a
              href="tel:+447929771954"
              class="inline-flex items-center gap-2 bg-brand-forest text-white
                     px-6 py-3 rounded-[8px] text-sm font-semibold
                     hover:bg-brand-forest-dark hover:shadow-cta hover:-translate-y-0.5
                     transition-all duration-200"
            >
              <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
              </svg>
              07929 771954
            </a>
            <a
              href="/contact"
              class="inline-flex items-center gap-2 border border-white/20 text-white/80
                     px-6 py-3 rounded-[8px] text-sm font-semibold
                     hover:border-brand-lime/50 hover:text-white
                     transition-all duration-200"
            >
              Send an Enquiry
              <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/>
              </svg>
            </a>
          </div>

        </div>
      </div>
    </div>
  </section>

  <!-- ── Coverage map ── -->
  <section class="py-12 sm:py-16 lg:py-20 bg-brand-dark-card border-t border-white/8">
    <div class="container mx-auto px-4 sm:px-6">

      <div class="max-w-2xl mb-8 sm:mb-10">
        <span class="text-xs font-semibold tracking-widest uppercase text-brand-lime mb-3 block">
          Service Area
        </span>
        <h2 class="text-2xl sm:text-3xl font-bold text-white mb-3">
          London &amp; the Home Counties
        </h2>
        <p class="text-sm sm:text-base text-white/60 leading-relaxed">
          We operate across the full Greater London area and all surrounding Home Counties —
          covering sites from Berkshire in the west to Essex in the east.
        </p>
      </div>

      <!-- Map -->
      <div
        id="coverage-map"
        class="w-full h-[380px] sm:h-[500px] lg:h-[580px] rounded-[16px] overflow-hidden border border-white/10 shadow-float"
        aria-label="Map showing WasteWize UK service coverage across London and the Home Counties"
      ></div>

      <!-- Legend -->
      <div class="mt-5 flex flex-wrap items-center gap-5 text-xs text-white/50">
        <span class="flex items-center gap-2">
          <span class="w-4 h-4 rounded-sm shrink-0" style="background:#8BC34A;opacity:0.55;border:1.5px solid #8BC34A;"></span>
          Greater London
        </span>
        <span class="flex items-center gap-2">
          <span class="w-4 h-4 rounded-sm shrink-0" style="background:#4CAF50;opacity:0.35;border:1.5px solid #4CAF50;"></span>
          Home Counties
        </span>
        <span class="ml-auto text-white/25 hidden sm:block">
          © OpenStreetMap contributors © CARTO
        </span>
      </div>

    </div>
  </section>

</Layout>

<script is:inline>
document.addEventListener('click', function (e) {
  var btn = e.target.closest('[data-target]');
  if (!btn) return;
  var panel = document.getElementById(btn.dataset.target);
  if (!panel) return;
  var nowHidden = panel.classList.toggle('hidden');
  panel.classList.toggle('flex');
  btn.textContent = nowHidden ? '+' + btn.dataset.count + ' more' : 'Show less';
});
</script>

<script is:inline>
(function () {
  /* ── Load Leaflet CSS + JS from CDN, then init map ── */
  function loadLeaflet(cb) {
    if (window.L) { cb(); return; }

    const css = document.createElement('link');
    css.rel  = 'stylesheet';
    css.href = 'https://unpkg.com/leaflet@1.9.4/dist/leaflet.css';
    document.head.appendChild(css);

    const js = document.createElement('script');
    js.src   = 'https://unpkg.com/leaflet@1.9.4/dist/leaflet.js';
    js.onload = cb;
    document.head.appendChild(js);
  }

  function initMap() {
    const el = document.getElementById('coverage-map');
    if (!el || el._leaflet_id) return;

    const map = L.map('coverage-map', {
      center: [51.52, -0.30],
      zoom: 9,
      scrollWheelZoom: false,   // prevent page hijack on scroll
      zoomControl: true,
    });

    /* Dark tiles — matches site theme */
    L.tileLayer('https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png', {
      subdomains: 'abcd',
      maxZoom: 19,
      attribution: '',
    }).addTo(map);

    /* ── Greater London boundary (approximate M25 inner) ── */
    const london = [
      [51.686, -0.216], [51.692, -0.077], [51.661, 0.017],
      [51.617, 0.050],  [51.575, 0.105],  [51.551, 0.218],
      [51.510, 0.225],  [51.461, 0.145],  [51.402, 0.062],
      [51.372, -0.014], [51.355, -0.100], [51.362, -0.205],
      [51.400, -0.318], [51.430, -0.380], [51.468, -0.388],
      [51.510, -0.472], [51.535, -0.456], [51.578, -0.386],
      [51.623, -0.298], [51.657, -0.247], [51.686, -0.216],
    ];

    /* ── Home Counties outer boundary ── */
    const homeCounties = [
      /* Hertfordshire (north) */
      [51.800, -0.380], [51.840, -0.220], [51.820, -0.040],
      /* Essex (east) */
      [51.745, 0.125],  [51.740, 0.480],  [51.620, 0.480],
      [51.580, 0.470],  [51.540, 0.450],
      /* Kent (southeast) */
      [51.455, 0.360],  [51.290, 0.260],  [51.185, 0.280],
      [51.100, 0.080],  [51.090, -0.085],
      /* Surrey (south) */
      [51.140, -0.195], [51.175, -0.400], [51.195, -0.570],
      [51.220, -0.780],
      /* Berkshire (west) */
      [51.330, -0.755], [51.380, -0.970], [51.460, -1.000],
      [51.540, -1.000],
      /* Buckinghamshire (northwest) */
      [51.625, -0.900], [51.640, -0.760],
      [51.828, -0.830],
      /* Back to Hertfordshire */
      [51.810, -0.620], [51.800, -0.380],
    ];

    /* Draw Home Counties first (underneath) */
    L.polygon(homeCounties, {
      color:       '#4CAF50',
      fillColor:   '#4CAF50',
      fillOpacity: 0.12,
      weight:      2,
      opacity:     0.55,
    }).addTo(map);

    /* Draw Greater London on top */
    L.polygon(london, {
      color:       '#8BC34A',
      fillColor:   '#8BC34A',
      fillOpacity: 0.25,
      weight:      2,
      opacity:     0.85,
    }).addTo(map);

    /* Fit view to show both polygons with padding */
    const bounds = L.latLngBounds([...london, ...homeCounties]);
    map.fitBounds(bounds, { padding: [30, 30] });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', () => loadLeaflet(initMap));
  } else {
    loadLeaflet(initMap);
  }
})();
</script>
