---
import Layout from '../layouts/Layout.astro';

const BASE = 'https://wastewize.co.uk';

const servicePrices = [
  {
    category: 'Small Cage Van (3.5-Tonne)',
    rows: [
      { service: 'Small Cage Van — Half Load', from: '£180', basis: '—', note: 'Up to 7 cubic yards | Max 600 kg' },
      { service: 'Small Cage Van — Full Load', from: '£350', basis: '—', note: 'Up to 14 cubic yards | Max 1,200 kg' },
      { service: 'Ideal for:', from: 'Urban access', basis: 'Narrow streets', note: 'Shop and office rip-outs, medium residential clearances' },
    ],
  },
  {
    category: 'Large Cage Van (7.5-Tonne)',
    rows: [
      { service: 'Large Cage Van — Half Load', from: '£200', basis: '—', note: 'Extended volume capacity' },
      { service: 'Large Cage Van — Full Load', from: '£400', basis: '—', note: 'Full commercial capacity' },
      { service: 'Ideal for:', from: 'Commercial sites', basis: 'Multi-room', note: 'Major strip-outs and corporate decommissions' },
    ],
  },
  {
    category: 'Heavy & Regulated Construction Waste',
    rows: [
      { service: 'Hardcore & Rubble Removal', from: '£Quote', basis: 'By weight', note: 'Concrete, brick, and aggregates — priced by payload, not cubic yards.' },
      { service: 'Construction Timber Removal', from: '£Quote', basis: 'By volume', note: 'Structural wood, joists, and softwood sorted for biomass recycling.' },
      { service: 'Plasterboard (Gypsum) — Regulated', from: '£Quote', basis: 'Segregated', note: 'Must be kept separate from other waste under UK environmental law.' },
    ],
  },
];

const faqs = [
  {
    q: 'How does your pricing work?',
    a: 'We price by van size and load — half or full. Whether you need the small 3.5-tonne van for tight urban access or the larger 7.5-tonne for a commercial strip-out, the rate covers everything: crew, transport, and disposal.',
  },
  {
    q: 'Why are heavy construction materials quoted separately?',
    a: 'Hardcore, brick, and concrete hit vehicle weight limits before they fill the space — so we price them by payload, not cubic yards. Plasterboard is a separate issue: UK law requires it to be kept completely separate from other waste, which means separate handling and disposal costs.',
  },
  {
    q: 'Are there any hidden fees?',
    a: 'No. The fixed rate covers our 2-man crew collecting, loading, sweeping up, and disposing of your waste legally. Dump fees, fuel, and labour are all included. Surcharges apply only to specialist items like fridges or commercial appliances that require EA-regulated disposal.',
  },
  {
    q: 'Is VAT included in these prices?',
    a: 'Guide prices on this page exclude VAT. VAT at the applicable statutory rate is added to your final invoice.',
  },
  {
    q: 'Is WasteWize cheaper than hiring a skip?',
    a: 'Often cheaper, especially across London. Skips placed on a public road need a council permit (£50–£100+), and you have to load them yourself. We arrive with a 2-man team, pack the van to maximise value, and leave the area clean — saving you time, labour, and permit admin.',
  },
];
---

<Layout
  title="Waste Removal Prices London 2026 | Van Load Rates | WasteWize UK"
  description="Transparent waste removal rates for London and the Home Counties. Small cage van half loads from £180, full loads from £350. Heavy hardcore, timber, and plasterboard specialists. EA Licensed."
>

  <Fragment slot="head">
    <script type="application/ld+json" is:inline set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "LocalBusiness",
      "name": "WasteWize UK",
      "url": BASE,
      "telephone": "+447929771954",
      "priceRange": "££",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "37B Euro Storage Compound, 2B Canal Way",
        "addressLocality": "London",
        "postalCode": "W10 5AY",
        "addressCountry": "GB"
      },
      "areaServed": {
        "@type": "AdministrativeArea",
        "name": "London and the Home Counties"
      }
    })} />

    <script type="application/ld+json" is:inline set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home",   "item": `${BASE}/` },
        { "@type": "ListItem", "position": 2, "name": "Prices", "item": `${BASE}/prices` },
      ]
    })} />

    <script type="application/ld+json" is:inline set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": faqs.map(({ q, a }) => ({
        "@type": "Question",
        "name": q,
        "acceptedAnswer": { "@type": "Answer", "text": a }
      }))
    })} />
  </Fragment>

  <nav aria-label="Breadcrumb" class="bg-brand-dark border-b border-white/8">
    <div class="container mx-auto px-4 sm:px-6 py-3">
      <ol class="flex flex-wrap items-center gap-1.5 text-xs text-white/40">
        <li><a href="/" class="hover:text-white/70 transition-colors">Home</a></li>
        <li aria-hidden="true" class="text-white/20">/</li>
        <li class="text-white/70" aria-current="page">Prices</li>
      </ol>
    </div>
  </nav>

  <section class="bg-brand-dark py-14 sm:py-20 border-b border-white/8">
    <div class="container mx-auto px-4 sm:px-6 max-w-3xl">
      <span class="text-xs font-semibold tracking-widest uppercase text-brand-lime mb-4 block">
        Transparent fixed rates · Fleet ULEZ compliant
      </span>
      <h1 class="font-display text-4xl sm:text-5xl font-extrabold text-white mb-5 leading-[1.06]">
        Fixed Van Clearance Rates<br />
        <span class="text-brand-lime">London &amp; Home Counties</span>
      </h1>
      <p class="text-lg text-white/60 leading-relaxed mb-8 max-w-2xl">
        Pick a van size based on how much you need to shift. All prices include the crew, transport, and disposal — nothing added afterward.
      </p>
      <div class="flex flex-wrap gap-4">
        <a href="tel:+447929771954"
           class="inline-flex items-center gap-2 bg-brand-forest text-white px-7 py-3.5 rounded-[8px] text-sm font-semibold hover:bg-brand-forest-dark hover:-translate-y-0.5 hover:shadow-cta transition-all duration-200">
          <svg class="w-4 h-4 shrink-0" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
            <path d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z"/>
          </svg>
          Call for an instant quote
        </a>
        <a href="/contact"
           class="inline-flex items-center gap-2 border border-white/20 text-white/80 px-7 py-3.5 rounded-[8px] text-sm font-semibold hover:border-brand-lime/50 hover:text-white transition-all duration-200">
          Send photos for a fixed price →
        </a>
      </div>
    </div>
  </section>


  <section class="py-14 sm:py-18 bg-brand-dark border-b border-white/8">
    <div class="container mx-auto px-4 sm:px-6">
      <div class="flex flex-col gap-12">
        {servicePrices.map(({ category, rows }) => (
          <div>
            <h2 class="text-xl font-bold text-white mb-5 flex items-center gap-3">
              <span class="w-1 h-6 bg-brand-lime rounded-full shrink-0" aria-hidden="true"/>
              {category}
            </h2>
            <div class="overflow-x-auto rounded-[12px] border border-white/10">
              <table class="w-full text-sm">
                <thead>
                  <tr class="bg-brand-dark-card border-b border-white/10">
                    <th class="text-left px-5 py-3.5 text-white/40 font-semibold uppercase tracking-wider text-xs">Service</th>
                    <th class="text-left px-5 py-3.5 text-white/40 font-semibold uppercase tracking-wider text-xs">Price (from)</th>
                    <th class="text-left px-5 py-3.5 text-white/40 font-semibold uppercase tracking-wider text-xs">Basis</th>
                    <th class="text-left px-5 py-3.5 text-white/40 font-semibold uppercase tracking-wider text-xs hidden sm:table-cell">Notes</th>
                  </tr>
                </thead>
                <tbody>
                  {rows.map(({ service, from, basis, note }, i) => (
                    <tr class={`border-b border-white/6 last:border-0 ${i % 2 === 0 ? 'bg-brand-dark' : 'bg-brand-dark-card/30'}`}>
                      <td class="px-5 py-3.5 text-white/80 font-medium">{service}</td>
                      <td class="px-5 py-3.5 text-brand-lime font-bold text-base">{from}</td>
                      <td class="px-5 py-3.5 text-white/60">{basis}</td>
                      <td class="px-5 py-3.5 text-white/40 text-xs hidden sm:table-cell">{note}</td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          </div>
        ))}
      </div>

      <div class="mt-8 bg-brand-dark-card border border-brand-lime/20 rounded-[12px] px-6 py-5">
        <p class="text-sm text-white/60 leading-relaxed">
          <strong class="text-white">All prices exclude VAT.</strong> Rates apply to standard mixed waste loads. Regulated building waste (plasterboard, structural timber) or inert aggregates are quoted individually after a photo or site visit. <a href="/contact" class="text-brand-lime hover:underline underline-offset-2">Contact us</a> to book your slot.
        </p>
      </div>
    </div>
  </section>

  <section class="py-14 sm:py-18 bg-brand-dark border-b border-white/8">
    <div class="container mx-auto px-4 sm:px-6">
      <h2 class="text-2xl font-bold text-white mb-8">What every quote includes</h2>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {[
          { label: 'Two-person crew', desc: 'We handle all loading from any floor. No need to move anything beforehand.' },
          { label: 'EA-licensed disposal', desc: 'Waste Carrier Licence CBDU335711. All waste sorted and disposed of in line with EA regulations.' },
          { label: 'Duty of Care transfer notes', desc: 'Issued on every job, on-site. Full commercial compliance documentation as standard.' },
          { label: '99% landfill diversion', desc: 'Careful sorting keeps timber, metals, and clean hardcore out of landfill.' },
          { label: 'Fuel and transport included', desc: 'No mileage charges or ULEZ surcharges added on afterward.' },
          { label: 'Same-day and next-day slots', desc: 'Available for emergency commercial handovers across London.' },
        ].map(({ label, desc }) => (
          <div class="flex gap-4 bg-brand-dark-card border border-white/10 rounded-[12px] p-5">
            <svg class="w-5 h-5 text-brand-lime shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
            </svg>
            <div>
              <p class="text-[14px] font-semibold text-white mb-1">{label}</p>
              <p class="text-sm text-white/50">{desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-14 sm:py-18 bg-brand-dark border-b border-white/8" aria-labelledby="prices-faq-heading">
    <div class="container mx-auto px-4 sm:px-6 max-w-2xl">
      <h2 id="prices-faq-heading" class="font-display text-2xl sm:text-3xl font-bold text-white mb-8">
        Pricing FAQ
      </h2>
      <div class="flex flex-col gap-4">
        {faqs.map(({ q, a }) => (
          <div class="bg-brand-dark-card border border-white/10 rounded-[12px] p-6">
            <div class="text-[15px] font-semibold text-white mb-2 flex items-start gap-3">
              <span class="text-brand-lime shrink-0 mt-0.5" aria-hidden="true">Q</span>
              <span>{q}</span>
            </div>
            <div class="text-sm leading-relaxed text-white/60 pl-6">{a}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-14 sm:py-20 bg-brand-dark-card border-t border-white/8">
    <div class="container mx-auto px-4 sm:px-6 max-w-xl text-center">
      <h2 class="font-display text-2xl sm:text-3xl font-bold text-white mb-3">Get your exact price</h2>
      <p class="text-white/60 mb-8 leading-relaxed">
        Send us site photos or call directly — we'll work out the right van size and give you a fixed all-in price.
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-3">
        <a href="tel:+447929771954"
           class="w-full sm:w-auto inline-flex items-center justify-center gap-2 bg-brand-forest text-white px-8 py-4 rounded-[8px] text-base font-semibold hover:bg-brand-forest-dark hover:shadow-cta hover:-translate-y-0.5 transition-all duration-200">
          <svg class="w-5 h-5 shrink-0" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
            <path d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z"/>
          </svg>
          07929 771954
        </a>
        <a href="/contact"
           class="w-full sm:w-auto inline-flex items-center justify-center gap-2 border border-white/20 text-white/80 px-8 py-4 rounded-[8px] text-base font-semibold hover:border-brand-lime/50 hover:text-white transition-all duration-200">
          Contact form →
        </a>
      </div>
    </div>
  </section>

</Layout>
