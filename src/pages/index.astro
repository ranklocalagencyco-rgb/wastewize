---
// src/pages/index.astro
// Homepage — Layout 91 section sequence:
//   TopBar → Navbar (via BaseLayout) → Hero →
//   ServicesGrid → StatsBar → [Process] → [CTA Banner] → Footer (via BaseLayout)

import Layout    from '../layouts/Layout.astro';
import Hero          from '../components/Hero.astro';
import ServicesGrid  from '../components/ServicesGrid.astro';
import StatsBar      from '../components/StatsBar.astro';
---

<Layout
  title="WasteWize UK | Waste Removal for Homeowners & Businesses — London & Home Counties"
  description="EA-licensed waste removal for homeowners and businesses across London & the Home Counties. House clearances, commercial collections, recycling & more. 99% landfill diversion. Same-week availability."
>

  <Fragment slot="head">
    <!-- Preload LCP hero image so browser fetches it before parsing <body> -->
    <link rel="preload" as="image" href="/wastewize-tipper-in-central-london.webp" fetchpriority="high" />

    <script type="application/ld+json" is:inline set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "LocalBusiness",
      "name": "WasteWize UK",
      "image": "https://www.wastewize.co.uk/wastewizeuk-favicon.png",
      "@id": "https://www.wastewize.co.uk",
      "url": "https://www.wastewize.co.uk",
      "telephone": "+447929771954",
      "email": "info@wastewize.co.uk",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "9 Cordelia Court, Burns Lane",
        "addressLocality": "London",
        "postalCode": "NW7 2GB",
        "addressCountry": "GB"
      },
      "geo": {
        "@type": "GeoCoordinates",
        "latitude": 51.6152,
        "longitude": -0.2229
      },
      "openingHoursSpecification": {
        "@type": "OpeningHoursSpecification",
        "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday"],
        "opens": "08:00",
        "closes": "18:00"
      },
      "sameAs": [
        "https://www.facebook.com/people/WastewizeLtd/61586085284705/",
        "https://www.instagram.com/wastewizeltd"
      ],
      "areaServed": [
        { "@type": "AdministrativeArea", "name": "London" },
        { "@type": "AdministrativeArea", "name": "Home Counties" }
      ],
      "description": "WasteWize UK offers end-to-end homeowners and commercial waste removal and collection services with a 99% landfill diversion rate across London and the Home Counties."
    })} />
  </Fragment>

  <!-- 1. Hero — split layout, headline + CTA left, image right -->
  <Hero />

  <!-- 3. Services grid — 6 service cards in a 3-col grid -->
  <ServicesGrid />

  <!-- 4. Stats band — animated counters on forest-green background -->
  <StatsBar />

  <!-- ────────────────────────────────────────────────────
       5. Process Steps  (Audit → Collection → Recovery → Reporting)
          Add <ProcessSteps /> here in the next sprint
       ──────────────────────────────────────────────────── -->

  <!-- ────────────────────────────────────────────────────
       6. CTA Banner  ("Ready to lower your waste costs?")
          Add <CTABanner /> here in the next sprint
       ──────────────────────────────────────────────────── -->

</Layout>
