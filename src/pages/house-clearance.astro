---
import Layout from '../layouts/Layout.astro';

const BASE = 'https://wastewize.co.uk';

const faqs = [
  {
    q: 'How much does house clearance cost in London?',
    a: 'House clearance in London typically costs between £150 for a single room and £900 for a full three-bedroom property. Prices depend on the volume of items, access, and whether any specialist items (white goods, electronics, hazardous materials) are involved. WasteWize provides a free, no-obligation quote within 2 hours.',
  },
  {
    q: 'How quickly can you clear a house in London?',
    a: 'WasteWize offers same-week availability across London and the Home Counties, with next-day service available in most areas. For urgent probate or bereavement clearances, call 07929 771954 and we will do our best to accommodate you.',
  },
  {
    q: 'Do I need to be present during the house clearance?',
    a: 'No — key access is sufficient. Many of our customers are landlords, letting agents, and executors who are not on-site during clearance. We work safely and securely and will update you by phone when the job is complete.',
  },
  {
    q: 'What happens to the items you remove?',
    a: 'We achieve a 99% landfill diversion rate. Usable furniture and items are donated to local charities. Metals go to certified recyclers. Electronics are processed under WEEE regulations. Only items that cannot be recovered go to energy-from-waste facilities — nothing goes to landfill if we can help it.',
  },
  {
    q: 'Are you licensed to carry out house clearances?',
    a: 'Yes. WasteWize UK holds an Upper-Tier Environment Agency Waste Carrier Licence (CBDU335711) and £5m public liability insurance. You receive a Duty of Care Waste Transfer Note on every clearance — your legal protection under the Environmental Protection Act 1990.',
  },
  {
    q: 'Do you clear everything — including items in bad condition?',
    a: 'Yes, we take everything regardless of condition: old furniture, white goods, garden rubbish, accumulated clutter, and mixed waste. No skips, no permits, no sorting required from you.',
  },
];

const pricingRows = [
  { size: 'Single Room / Studio',        low: '£150', high: '£300',  note: 'One load'     },
  { size: '1-Bedroom Flat',             low: '£250', high: '£400',  note: 'One–two loads' },
  { size: '2-Bedroom House / Flat',     low: '£350', high: '£550',  note: 'Two loads'     },
  { size: '3-Bedroom House',            low: '£450', high: '£700',  note: 'Two–three loads'},
  { size: '4–5 Bedroom House',          low: '£600', high: '£950',  note: 'Three+ loads'  },
  { size: 'Full Estate / Large Property',low: 'POA', high: 'POA',   note: 'Site survey'   },
];
---

<Layout
  title="House Clearance London & Home Counties | EA Licensed | WasteWize UK"
  description="Professional house clearance across London and the Home Counties. EA-licensed, fully insured, 99% landfill diversion. From £150. Free no-obligation quote — same-week availability."
>

  <Fragment slot="head">
    <script type="application/ld+json" is:inline set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home",            "item": `${BASE}/` },
        { "@type": "ListItem", "position": 2, "name": "House Clearance", "item": `${BASE}/house-clearance` },
      ]
    })} />

    <script type="application/ld+json" is:inline set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Service",
      "name": "House Clearance London",
      "url": `${BASE}/house-clearance`,
      "description": "Professional full-property house clearance for homeowners, landlords, and estate executors across London and the Home Counties. EA-licensed, 99% landfill diversion, same-week availability.",
      "serviceType": "House Clearance",
      "areaServed": [
        { "@type": "AdministrativeArea", "name": "London" },
        { "@type": "AdministrativeArea", "name": "Surrey" },
        { "@type": "AdministrativeArea", "name": "Middlesex" },
        { "@type": "AdministrativeArea", "name": "Hertfordshire" },
        { "@type": "AdministrativeArea", "name": "Essex" },
        { "@type": "AdministrativeArea", "name": "Berkshire" },
        { "@type": "AdministrativeArea", "name": "Kent" },
      ],
      "provider": {
        "@type": "LocalBusiness",
        "name": "WasteWize UK",
        "url": BASE,
        "telephone": "+447929771954",
        "address": {
          "@type": "PostalAddress",
          "streetAddress": "37B Euro Storage Compound, 2B Canal Way",
          "addressLocality": "London",
          "postalCode": "W10 5AY",
          "addressCountry": "GB"
        }
      },
      "offers": {
        "@type": "AggregateOffer",
        "priceCurrency": "GBP",
        "lowPrice": "150",
        "highPrice": "950",
        "offerCount": "6"
      }
    })} />

    <script type="application/ld+json" is:inline set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": faqs.map(({ q, a }) => ({
        "@type": "Question",
        "name": q,
        "acceptedAnswer": { "@type": "Answer", "text": a }
      }))
    })} />
  </Fragment>

  <!-- Breadcrumb -->
  <nav aria-label="Breadcrumb" class="bg-brand-dark border-b border-white/8">
    <div class="container mx-auto px-4 sm:px-6 py-3">
      <ol class="flex flex-wrap items-center gap-1.5 text-xs text-white/40">
        <li><a href="/" class="hover:text-white/70 transition-colors">Home</a></li>
        <li aria-hidden="true" class="text-white/20">/</li>
        <li class="text-white/70" aria-current="page">House Clearance</li>
      </ol>
    </div>
  </nav>

  <!-- Hero -->
  <section class="bg-brand-dark py-14 sm:py-20 lg:py-24 border-b border-white/8">
    <div class="container mx-auto px-4 sm:px-6">
      <div class="max-w-3xl">
        <span class="text-xs font-semibold tracking-widest uppercase text-brand-lime mb-4 block">
          House Clearance · London &amp; Home Counties
        </span>
        <h1 class="font-display text-4xl sm:text-5xl lg:text-6xl font-extrabold text-white mb-5 leading-[1.06]">
          House Clearance<br />
          <span class="text-brand-lime">London &amp; Home Counties</span>
        </h1>
        <p class="text-lg sm:text-xl text-white/60 leading-relaxed max-w-2xl mb-8">
          Full-property clearances for homeowners, landlords, letting agents, and estate executors. We remove everything — furniture, white goods, garden rubbish, and accumulated clutter — from £150. EA-licensed, same-week availability.
        </p>
        <div class="flex flex-col sm:flex-row gap-3">
          <a href="tel:+447929771954"
             class="inline-flex items-center gap-2 bg-brand-forest text-white px-7 py-4 rounded-[8px] text-base font-semibold hover:bg-brand-forest-dark hover:-translate-y-0.5 hover:shadow-cta transition-all duration-200">
            <svg class="w-5 h-5 shrink-0" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
              <path d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z"/>
            </svg>
            Call 07929 771954
          </a>
          <a href="/contact"
             class="inline-flex items-center gap-2 border border-white/20 text-white/80 px-7 py-4 rounded-[8px] text-base font-semibold hover:border-brand-lime/50 hover:text-white transition-all duration-200">
            Get a Free Quote
            <svg class="w-5 h-5 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/>
            </svg>
          </a>
        </div>

        <!-- Trust strip -->
        <div class="mt-10 flex flex-wrap gap-5">
          {[
            { v: 'EA Licensed',      l: 'CBDU335711'         },
            { v: '£5m',              l: 'Public Liability'   },
            { v: '99%',              l: 'Landfill Diversion' },
            { v: 'Same Week',        l: 'Availability'       },
            { v: 'WTN Issued',       l: 'On Every Job'       },
          ].map(({ v, l }) => (
            <div class="flex flex-col">
              <span class="text-brand-lime font-bold text-lg">{v}</span>
              <span class="text-white/40 text-xs">{l}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>


  <!-- What we clear -->
  <section class="py-14 sm:py-18 bg-brand-dark border-b border-white/8">
    <div class="container mx-auto px-4 sm:px-6">
      <h2 class="text-2xl sm:text-3xl font-bold text-white mb-3">What We Clear</h2>
      <p class="text-white/60 mb-10 max-w-2xl">We take everything — no sorting required from you.</p>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {[
          { icon: 'M3 7h18M3 12h18M3 17h18', title: 'Furniture & Sofas',         desc: 'Beds, wardrobes, dining sets, sofas, armchairs — any size, any condition.' },
          { icon: 'M9 3H5a2 2 0 00-2 2v4m6-6h10a2 2 0 012 2v4M9 3v18m0 0h10a2 2 0 002-2V9M9 21H5a2 2 0 01-2-2V9m0 0h18', title: 'White Goods & Appliances',  desc: 'Fridges, freezers, washing machines, dishwashers, tumble dryers.' },
          { icon: 'M12 3v1m0 16v1M4.22 4.22l.707.707M18.364 18.364l.707.707M1 12h1m18 0h1M4.22 19.778l.707-.707M18.364 5.636l.707-.707', title: 'Garden Waste & Sheds',    desc: 'Outdoor furniture, garden tools, shed contents, timber and decking.' },
          { icon: 'M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z', title: 'Loft & Garage Contents',  desc: 'Decades of accumulated items, boxes, tools, sports equipment.' },
          { icon: 'M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z', title: 'Electronics (WEEE)',       desc: 'TVs, computers, monitors, printers — WEEE-compliant disposal.' },
          { icon: 'M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16', title: 'General Household Clutter', desc: 'Mixed bags, boxes, kitchen items — cleared in a single visit.' },
        ].map(({ icon, title, desc }) => (
          <div class="bg-brand-dark-card border border-white/10 rounded-[12px] p-6 flex gap-4">
            <div class="w-10 h-10 rounded-[8px] bg-brand-lime/10 flex items-center justify-center shrink-0">
              <svg class="w-5 h-5 text-brand-lime" fill="none" stroke="currentColor" stroke-width="1.7" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d={icon}/>
              </svg>
            </div>
            <div>
              <h3 class="text-[15px] font-semibold text-white mb-1">{title}</h3>
              <p class="text-sm text-white/50 leading-relaxed">{desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- How it works -->
  <section class="py-16 sm:py-20 bg-brand-dark-card border-b border-white/8" aria-labelledby="process-heading">
    <div class="container mx-auto px-4 sm:px-6 max-w-5xl">
      <div class="text-center mb-12">
        <span class="text-xs font-semibold tracking-widest uppercase text-brand-lime mb-3 block">Step by Step</span>
        <h2 id="process-heading" class="font-display text-2xl sm:text-3xl font-bold text-white">
          How Our House Clearance Service Works
        </h2>
        <p class="mt-3 text-sm text-white/50 max-w-xl mx-auto">
          Every job follows the same documented process — from first contact to final Waste Transfer Note.
        </p>
      </div>
      <div class="relative">
        <div class="hidden lg:block absolute top-10 left-[8%] right-[8%] h-[2px]
                    bg-gradient-to-r from-brand-lime/20 via-brand-lime/50 to-brand-lime/20"
             aria-hidden="true"></div>
        <div class="grid grid-cols-2 lg:grid-cols-4 gap-6 lg:gap-4 relative z-10">
          {[
            { title: 'Free Quote',        desc: 'Call 07929 771954 or complete the form. We provide a fixed price within 2 hours.' },
            { title: 'Book a Date',       desc: 'Same-week or next-day availability across London and the Home Counties.' },
            { title: 'We Arrive & Clear', desc: 'Our two-person team removes everything — no sorting required from you.' },
            { title: 'WTN Issued',        desc: 'You receive an EA Waste Transfer Note confirming legal, compliant disposal.' },
          ].map(({ title, desc }, i) => (
            <div class="flex flex-col items-center text-center gap-3">
              <div class="w-20 h-20 rounded-full bg-brand-dark border-2 border-brand-lime/30
                          flex items-center justify-center relative shrink-0
                          hover:border-brand-lime hover:bg-brand-lime/10
                          transition-all duration-300 group/step">
                <span class="text-brand-lime font-bold text-lg group-hover/step:scale-110 transition-transform duration-300">
                  {String(i + 1).padStart(2, '0')}
                </span>
                <span class="absolute -top-2 -right-2 w-6 h-6 rounded-full bg-brand-lime
                             text-[10px] font-bold text-brand-dark flex items-center
                             justify-center leading-none" aria-hidden="true">
                  {i + 1}
                </span>
              </div>
              <div>
                <p class="text-sm font-semibold text-white mb-1">{title}</p>
                <p class="text-[11px] text-white/40 leading-snug">{desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Pricing table -->
  <section class="py-14 sm:py-18 bg-brand-dark border-b border-white/8" id="prices">
    <div class="container mx-auto px-4 sm:px-6">
      <h2 class="text-2xl sm:text-3xl font-bold text-white mb-3">House Clearance Prices London</h2>
      <p class="text-white/60 mb-10 max-w-2xl">Guide prices — final quote depends on volume and access. All prices include labour, transport, and EA-licensed disposal. No hidden fees.</p>
      <div class="overflow-x-auto rounded-[12px] border border-white/10">
        <table class="w-full text-sm">
          <thead>
            <tr class="bg-brand-dark-card border-b border-white/10">
              <th class="text-left px-5 py-4 text-white/50 font-semibold uppercase tracking-wider text-xs">Property Size</th>
              <th class="text-left px-5 py-4 text-white/50 font-semibold uppercase tracking-wider text-xs">From</th>
              <th class="text-left px-5 py-4 text-white/50 font-semibold uppercase tracking-wider text-xs">Up to</th>
              <th class="text-left px-5 py-4 text-white/50 font-semibold uppercase tracking-wider text-xs">Typical Loads</th>
            </tr>
          </thead>
          <tbody>
            {pricingRows.map(({ size, low, high, note }, i) => (
              <tr class={`border-b border-white/6 last:border-0 ${i % 2 === 0 ? 'bg-brand-dark' : 'bg-brand-dark-card/40'}`}>
                <td class="px-5 py-4 text-white font-medium">{size}</td>
                <td class="px-5 py-4 text-brand-lime font-bold">{low}</td>
                <td class="px-5 py-4 text-white/70">{high}</td>
                <td class="px-5 py-4 text-white/40 text-xs">{note}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      <p class="mt-4 text-xs text-white/30">Prices exclude VAT. Specialist items (asbestos, hazardous materials) quoted separately. <a href="/contact" class="text-brand-lime hover:underline">Get your exact quote →</a></p>
    </div>
  </section>

  <!-- Who we serve -->
  <section class="py-14 sm:py-18 bg-brand-dark border-b border-white/8">
    <div class="container mx-auto px-4 sm:px-6">
      <h2 class="text-2xl sm:text-3xl font-bold text-white mb-3">Who Uses Our House Clearance Service</h2>
      <p class="text-white/60 mb-10 max-w-2xl">We work with everyone from private homeowners to national property management companies.</p>
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-5">
        {[
          { title: 'Homeowners',         desc: 'Downsizing, moving, or refreshing a property — we make it quick and painless.' },
          { title: 'Landlords',          desc: 'End-of-tenancy clearances turned around fast so your property is back on the market.' },
          { title: 'Estate Executors',   desc: 'Sensitive probate and bereavement clearances handled with care and discretion.' },
          { title: 'Letting Agents',     desc: 'Regular account arrangements available for agents managing multiple properties.' },
        ].map(({ title, desc }) => (
          <div class="bg-brand-dark-card border border-white/10 rounded-[12px] p-6">
            <h3 class="text-[15px] font-semibold text-brand-lime mb-2">{title}</h3>
            <p class="text-sm text-white/50 leading-relaxed">{desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="py-14 sm:py-18 bg-brand-dark border-b border-white/8" aria-labelledby="hc-faq-heading">
    <div class="container mx-auto px-4 sm:px-6 max-w-2xl mx-auto">
      <h2 id="hc-faq-heading" class="font-display text-2xl sm:text-3xl font-bold text-white mb-8">
        House Clearance FAQ
      </h2>
      <dl class="flex flex-col gap-4">
        {faqs.map(({ q, a }) => (
          <div class="bg-brand-dark-card border border-white/10 rounded-[12px] p-6">
            <dt class="text-[15px] font-semibold text-white mb-2 flex items-start gap-3">
              <span class="text-brand-lime shrink-0 mt-0.5" aria-hidden="true">Q</span>
              {q}
            </dt>
            <dd class="text-sm leading-relaxed text-white/60 pl-6">{a}</dd>
          </div>
        ))}
      </dl>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-14 sm:py-20 bg-brand-dark-card border-t border-white/8">
    <div class="container mx-auto px-4 sm:px-6 max-w-2xl mx-auto text-center">
      <h2 class="font-display text-2xl sm:text-3xl font-bold text-white mb-3">
        Ready to Book Your House Clearance?
      </h2>
      <p class="text-white/60 mb-8 leading-relaxed">
        Call us for an instant quote — or complete the form and we'll respond within 2 hours. Same-week availability across London &amp; the Home Counties.
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-3">
        <a href="tel:+447929771954"
           class="w-full sm:w-auto inline-flex items-center justify-center gap-2 bg-brand-forest text-white px-8 py-4 rounded-[8px] text-base font-semibold hover:bg-brand-forest-dark hover:shadow-cta hover:-translate-y-0.5 transition-all duration-200">
          <svg class="w-5 h-5 shrink-0" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
            <path d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z"/>
          </svg>
          07929 771954
        </a>
        <a href="/contact"
           class="w-full sm:w-auto inline-flex items-center justify-center gap-2 border border-white/20 text-white/80 px-8 py-4 rounded-[8px] text-base font-semibold hover:border-brand-lime/50 hover:text-white transition-all duration-200">
          Send an Enquiry →
        </a>
      </div>
    </div>
  </section>

</Layout>
