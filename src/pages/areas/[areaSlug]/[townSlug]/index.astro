---
import Layout from '../../../../layouts/Layout.astro';
import { areas } from '../../../../data/areas';
import { services } from '../../../../data/services';
import { serviceDetails } from '../../../../data/service-detail';
import { townDetails } from '../../../../data/town-detail';
import ReviewsWidget from '../../../../components/ReviewsWidget.astro';

export function getStaticPaths() {
  function slugify(str: string): string {
    return str.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '');
  }
  return areas.flatMap((area) =>
    area.towns.map((town) => ({
      params: {
        areaSlug: area.slug,
        townSlug:  slugify(town),
      },
      props: { town },
    }))
  );
}

function slugify(str: string): string {
  return str.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '');
}

interface Props {
  town: string;
}

function svcSlug(href: string): string {
  return href.startsWith('/services/') ? href.slice(10) : href.slice(1);
}

const { areaSlug } = Astro.params;
const { town }     = Astro.props;

// Always look up from the live import so edits to areas.ts are reflected immediately.
const area = areas.find((a) => a.slug === areaSlug)!;

const nearbyTowns = area.towns.filter((t) => t !== town);


const townKey     = `${areaSlug}/${slugify(town)}`;
const townSlugStr = slugify(town);
const svcForJs    = services.map((s) => {
  const slug = svcSlug(s.href);
  return {
    ...s,
    areaHref: serviceDetails[slug] !== undefined
      ? `/areas/${areaSlug}/${townSlugStr}/${slug}`
      : s.href,
  };
});
const detail      = townDetails[townKey] ?? null;
const pageTitle   = `${town} Waste Collection & Clearance | WasteWize UK`;
const pageDescription = detail?.metaDesc
  ?? `WasteWize UK provides commercial and residential waste collection, office clearance, and specialist disposal in ${town}, ${area.name}. EA licensed, same-week availability.`;
const heroIntro   = detail?.intro ?? area.desc;
const postcode    = detail?.postcode ?? null;
---

<Layout title={pageTitle} description={pageDescription}>

  <Fragment slot="head">
    <script type="application/ld+json" is:inline set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "LocalBusiness",
      "name": "WasteWize UK",
      "url": "https://wastewize.co.uk",
      "telephone": "+447929771954",
      "description": pageDescription,
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "37B Euro Storage Compound, 2B Canal Way",
        "addressLocality": "London",
        "postalCode": "W10 5AY",
        "addressCountry": "GB"
      },
      "areaServed": {
        "@type": "City",
        "name": town,
        "containedInPlace": { "@type": "AdministrativeArea", "name": area.name }
      },
      "hasOfferCatalog": {
        "@type": "OfferCatalog",
        "name": `Waste Management Services in ${town}`,
        "itemListElement": services.map((s) => ({
          "@type": "Offer",
          "itemOffered": { "@type": "Service", "name": s.title }
        }))
      }
    })} />

    <!-- Service schema -->
    <script type="application/ld+json" is:inline set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Service",
      "name": `Waste Removal Services in ${town}`,
      "serviceType": "Waste Management",
      "description": `Comprehensive waste removal for homeowners and commercial businesses in ${town}. We provide professional house clearances and trade waste collections with a 99% landfill diversion rate.`,
      "provider": {
        "@type": "LocalBusiness",
        "name": "WasteWize UK",
        "url": "https://wastewize.co.uk",
        "telephone": "+447929771954",
        "image": "https://wastewize.co.uk/wastewizeuk-favicon.png",
        "address": {
          "@type": "PostalAddress",
          "streetAddress": "37B Euro Storage Compound, 2B Canal Way",
          "addressLocality": "London",
          "postalCode": "W10 5AY",
          "addressCountry": "GB"
        }
      },
      "areaServed": {
        "@type": "City",
        "name": town
      },
      "hasOfferCatalog": {
        "@type": "OfferCatalog",
        "name": "WasteWize UK Service Directory",
        "itemListElement": [
          {
            "@type": "Offer",
            "itemOffered": {
              "@type": "Service",
              "name": "Commercial Waste Management",
              "description": `Tailored trade waste collection, recycling, and compliance documentation for businesses in ${town}.`
            }
          },
          {
            "@type": "Offer",
            "itemOffered": {
              "@type": "Service",
              "name": "Homeowner Waste Removal",
              "description": `Fast residential house clearances, furniture disposal, and garden waste removal for ${town} residents.`
            }
          }
        ]
      }
    })} />

    <!-- FAQ schema -->
    <script type="application/ld+json" is:inline set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": `Do you offer household clearances in ${town}?`,
          "acceptedAnswer": {
            "@type": "Answer",
            "text": `Yes — WasteWize UK provides full house clearances in ${town}, including furniture, appliances, and bulky items. We carry full public liability insurance and issue a Waste Transfer Note on every job.`
          }
        },
        {
          "@type": "Question",
          "name": `Can businesses in ${town} get a free waste audit?`,
          "acceptedAnswer": {
            "@type": "Answer",
            "text": `Yes. We offer a free on-site waste audit for commercial customers in ${town}. Our team will assess your current waste streams and recommend a compliant, cost-effective collection schedule.`
          }
        },
        {
          "@type": "Question",
          "name": `How quickly can you collect waste in ${town}?`,
          "acceptedAnswer": {
            "@type": "Answer",
            "text": `We offer same-week availability across ${town} and the surrounding ${area.name} area. In many cases we can arrange next-day collection — call 07929 771954 for availability.`
          }
        },
        {
          "@type": "Question",
          "name": `Are you EA-licensed to collect waste in ${town}?`,
          "acceptedAnswer": {
            "@type": "Answer",
            "text": `Yes. WasteWize UK holds an Environment Agency Waste Carrier Licence (CBDU335711), which covers all collections in ${town} and across London and the Home Counties. You will receive a Duty of Care Waste Transfer Note on every collection.`
          }
        }
      ]
    })} />

    <!-- Breadcrumb schema -->
    <script type="application/ld+json" is:inline set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home",           "item": "https://wastewize.co.uk/" },
        { "@type": "ListItem", "position": 2, "name": "Areas",          "item": "https://wastewize.co.uk/areas" },
        { "@type": "ListItem", "position": 3, "name": area.name,        "item": `https://wastewize.co.uk/areas#${area.slug}` },
        { "@type": "ListItem", "position": 4, "name": town }
      ]
    })} />
  </Fragment>

  <!-- ── Breadcrumb ── -->
  <nav aria-label="Breadcrumb" class="bg-brand-dark border-b border-white/8">
    <div class="container mx-auto px-4 sm:px-6 py-3">
      <ol class="flex flex-wrap items-center gap-1.5 text-xs text-white/40">
        <li><a href="/"      class="hover:text-white/70 transition-colors">Home</a></li>
        <li aria-hidden="true" class="text-white/20">/</li>
        <li><a href="/areas" class="hover:text-white/70 transition-colors">Areas</a></li>
        <li aria-hidden="true" class="text-white/20">/</li>
        <li><a href={`/areas#${area.slug}`} class="hover:text-white/70 transition-colors">{area.name}</a></li>
        <li aria-hidden="true" class="text-white/20">/</li>
        <li class="text-white/70" aria-current="page">{town}</li>
      </ol>
    </div>
  </nav>

  <!-- ── Hero ── -->
  <section class="bg-brand-dark py-12 sm:py-16 lg:py-20 border-b border-white/8">
    <div class="container mx-auto px-4 sm:px-6">
      <div class="max-w-2xl">
        <div class="flex flex-wrap items-center gap-2 mb-3">
          <span class="text-xs font-semibold tracking-widest uppercase text-brand-lime">
            {area.region} · {area.name}
          </span>
          {postcode && (
            <span class="text-[10px] font-medium bg-brand-lime/10 border border-brand-lime/20 text-brand-lime rounded-full px-2 py-0.5">
              {postcode}
            </span>
          )}
        </div>
        <h1 class="font-display text-3xl sm:text-4xl lg:text-5xl font-bold text-white mb-4 leading-tight">
          Home &amp; Business Waste Clearance in {town}
        </h1>
        <p class="text-base sm:text-[17px] leading-relaxed text-white/60 max-w-xl">
          {heroIntro}
        </p>

        <div class="mt-8 flex flex-col sm:flex-row items-start gap-3">
          <a
            href="tel:+447929771954"
            class="inline-flex items-center gap-2 bg-brand-forest text-white
                   px-6 py-3 rounded-[8px] text-sm font-semibold
                   hover:bg-brand-forest-dark hover:shadow-cta hover:-translate-y-0.5
                   transition-all duration-200"
          >
            <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
            </svg>
            07929 771954
          </a>
          <a
            href="/contact"
            class="inline-flex items-center gap-2 border border-white/20 text-white/80
                   px-6 py-3 rounded-[8px] text-sm font-semibold
                   hover:border-brand-lime/50 hover:text-white
                   transition-all duration-200"
          >
            Get a Free Quote
            <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Trust stats -->
      <div class="mt-10 grid grid-cols-2 sm:grid-cols-4 gap-4 sm:gap-5 max-w-lg sm:max-w-none">
        {[
          { value: 'EA Licensed',  label: 'Fully Compliant'    },
          { value: '99%',          label: 'Landfill Diversion' },
          { value: 'Same Week',    label: 'Availability'       },
          { value: 'Duty of Care', label: 'Docs on Every Job'  },
        ].map(({ value, label }) => (
          <div class="bg-brand-dark-card border border-white/10 rounded-[10px] px-4 py-4 text-center">
            <p class="text-base sm:text-lg font-bold text-brand-lime leading-tight">{value}</p>
            <p class="text-[11px] text-white/50 mt-1">{label}</p>
          </div>
        ))}
      </div>
    </div>
  </section>


  <!-- ── Services grid ── -->
  <section class="py-12 sm:py-16 lg:py-20 bg-brand-dark" aria-labelledby="town-services-heading">
    <div class="container mx-auto px-4 sm:px-6">

      <!-- Header + count badge -->
      <div class="flex flex-col lg:flex-row lg:items-end lg:justify-between gap-6 mb-8 sm:mb-10">
        <div class="max-w-xl">
          <span class="text-xs font-semibold tracking-widest uppercase text-brand-lime mb-3 block">
            What We Do
          </span>
          <h2 id="town-services-heading" class="text-2xl sm:text-3xl font-bold text-white mb-3">
            Waste Services in {town}
          </h2>
          <p class="text-sm sm:text-base text-white/60 leading-relaxed">
            Every job in {town}{postcode ? ` (${postcode})` : ''} comes with full duty-of-care documentation,
            EA-licensed disposal, and a named contact from booking to completion.
          </p>
        </div>
        <div
          id="town-svc-count"
          class="shrink-0 flex items-center gap-2 bg-brand-lime/10 border border-brand-lime/30
                 rounded-full px-4 py-2 text-sm font-semibold text-brand-lime self-start lg:self-auto"
          aria-live="polite"
          aria-atomic="true"
        >
          <span class="w-2 h-2 rounded-full bg-brand-lime" aria-hidden="true"/>
          Showing all {services.length} services
        </div>
      </div>

      <!-- Filter tabs -->
      <div class="flex flex-wrap gap-2 mb-8" role="group" aria-label="Filter services by category">
        {[
          { cat: 'all',          label: 'All services' },
          { cat: 'clearance',    label: 'Clearance'    },
          { cat: 'construction', label: 'Construction' },
          { cat: 'specialist',   label: 'Specialist'   },
          { cat: 'materials',    label: 'Materials'    },
        ].map(({ cat, label }) => (
          <button
            type="button"
            data-town-cat={cat}
            class={[
              'town-filter-tab px-4 py-2 rounded-[8px] text-sm font-semibold border transition-all duration-200',
              cat === 'all'
                ? 'bg-brand-forest text-white border-brand-forest'
                : 'bg-brand-dark-card text-white/70 border-white/15 hover:border-brand-lime hover:text-brand-lime hover:bg-brand-lime/10',
            ].join(' ')}
            aria-pressed={cat === 'all' ? 'true' : 'false'}
          >
            {label}
          </button>
        ))}
      </div>

      <!-- 4-column service grid -->
      <div id="town-svc-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5" role="list">
        {services.map((svc) => (
          <article
            data-town-id={svc.id}
            data-town-cat={svc.cat}
            role="listitem"
            tabindex="0"
            aria-expanded="false"
            class="town-svc-card group bg-brand-dark-card border border-white/10 rounded-[12px] p-6
                   flex flex-col gap-4 cursor-pointer relative overflow-hidden
                   transition-all duration-300 hover:border-brand-lime/50 hover:shadow-card
                   hover:-translate-y-1 focus-visible:outline focus-visible:outline-2
                   focus-visible:outline-brand-lime focus-visible:outline-offset-2"
          >
            <div
              class="absolute top-0 left-0 right-0 h-[3px] bg-brand-lime rounded-t-[12px]
                     scale-x-0 group-hover:scale-x-100 origin-left transition-transform duration-300
                     town-card-accent"
              aria-hidden="true"
            />
            <div
              class="w-12 h-12 rounded-[10px] bg-brand-lime/10 flex items-center justify-center
                     shrink-0 transition-colors duration-300 group-hover:bg-brand-lime/20"
            >
              <svg
                class="w-6 h-6 text-brand-lime group-hover:text-white transition-colors duration-300"
                fill="none" stroke="currentColor" stroke-width="1.7" viewBox="0 0 24 24" aria-hidden="true"
              >
                <path stroke-linecap="round" stroke-linejoin="round" d={svc.icon}/>
              </svg>
            </div>
            <div class="flex flex-col gap-1.5 flex-1">
              <h3 class="text-[15px] font-semibold text-white leading-snug
                         group-hover:text-brand-lime transition-colors duration-200">
                {svc.title}
              </h3>
              <p class="text-[13px] leading-relaxed text-white/50">{svc.shortDesc}</p>
            </div>
            <div class="flex items-center justify-between">
              <span
                class="text-[11px] font-semibold tracking-wide uppercase px-2.5 py-1
                       rounded-full bg-brand-lime/15 text-brand-lime border border-brand-lime/30"
              >
                {svc.catLabel}
              </span>
              <svg
                class="w-4 h-4 text-white/30 group-hover:text-brand-lime transition-all duration-300 town-card-chevron"
                fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true"
              >
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
              </svg>
            </div>
          </article>
        ))}
      </div>

      <!-- Expand detail panel -->
      <div
        id="town-detail-panel"
        class="hidden mt-5 bg-brand-dark-card border border-white/10 rounded-[16px] overflow-hidden"
        aria-live="polite"
      >
        <div class="p-6 lg:p-8 flex flex-col sm:flex-row gap-6">
          <div class="w-14 h-14 rounded-[12px] bg-brand-dark-elevated border border-white/10
                      flex items-center justify-center shrink-0">
            <svg class="w-7 h-7" fill="none" stroke="#8BC34A" stroke-width="1.7"
                 viewBox="0 0 24 24" id="town-detail-icon-svg" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" id="town-detail-icon-path" d=""/>
            </svg>
          </div>
          <div class="flex-1 min-w-0">
            <h3 id="town-detail-title" class="font-display text-xl font-bold text-brand-lime mb-2"></h3>
            <p id="town-detail-desc" class="text-[14px] text-white/60 leading-relaxed mb-4"></p>
            <div id="town-detail-pills" class="flex flex-wrap gap-2 mb-5"></div>
            <div class="flex flex-wrap gap-3">
              <a
                id="town-detail-link"
                href="#"
                class="inline-flex items-center gap-2 bg-brand-forest text-white px-5 py-2.5
                       rounded-[8px] text-sm font-semibold hover:bg-brand-forest-dark
                       hover:shadow-cta transition-all duration-200"
              >
                Learn more
                <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2"
                     viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/>
                </svg>
              </a>
              <a
                href="/contact#quote"
                class="inline-flex items-center gap-2 border-2 border-brand-lime/50 text-brand-lime
                       px-5 py-2.5 rounded-[8px] text-sm font-semibold hover:bg-brand-lime/10
                       transition-all duration-200"
              >
                Get a quote for this service
              </a>
            </div>
          </div>
        </div>
      </div>

      <p class="mt-6 text-xs text-white/40">
        Need something not listed?
        <a href="/contact" class="text-brand-lime hover:underline underline-offset-2 ml-1">Get in touch</a>
        — we handle most specialist and mixed-load waste types.
      </p>
    </div>
  </section>

  <!-- ── Local context (towns with rich content only) ── -->
  {detail && detail.localContext && (
    <section class="py-12 sm:py-16 lg:py-20 bg-brand-dark border-t border-white/8" aria-labelledby="local-context-heading">
      <div class="container mx-auto px-4 sm:px-6">
        <div class="grid lg:grid-cols-3 gap-10 lg:gap-16">

          <!-- Prose column -->
          <div class="lg:col-span-2">
            <span class="text-xs font-semibold tracking-widest uppercase text-brand-lime mb-3 block">
              Local Knowledge
            </span>
            <h2 id="local-context-heading" class="text-2xl sm:text-3xl font-bold text-white mb-6">
              Waste Collection in {town}: What You Need to Know
            </h2>
            <div class="prose prose-sm prose-invert max-w-none text-white/60 leading-relaxed space-y-4">
              {detail.localContext.split('\n\n').map((para: string) => (
                <p>{para.trim()}</p>
              ))}
            </div>
          </div>

          <!-- Key areas sidebar -->
          {detail.keyAreas && detail.keyAreas.length > 0 && (
            <aside>
              <h3 class="text-sm font-semibold text-white/80 mb-4 uppercase tracking-wider">
                Key Areas &amp; Landmarks
              </h3>
              <ul class="flex flex-col gap-2">
                {detail.keyAreas.map((area: string) => (
                  <li class="flex items-center gap-2.5 text-sm text-white/60">
                    <span class="w-1.5 h-1.5 rounded-full bg-brand-lime shrink-0" aria-hidden="true"/>
                    {area}
                  </li>
                ))}
              </ul>

              {detail.topServices && detail.topServices.length > 0 && (
                <div class="mt-8">
                  <h3 class="text-sm font-semibold text-white/80 mb-4 uppercase tracking-wider">
                    Most Requested Services
                  </h3>
                  <div class="flex flex-col gap-2">
                    {detail.topServices.map((svcId: string) => {
                      const s = services.find((x) => x.id === svcId);
                      return s ? (
                        <a
                          href={s.href}
                          class="text-sm text-brand-lime hover:underline underline-offset-2 flex items-center gap-1.5"
                        >
                          <svg class="w-3.5 h-3.5 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/>
                          </svg>
                          {s.title}
                        </a>
                      ) : null;
                    })}
                  </div>
                </div>
              )}
            </aside>
          )}

        </div>
      </div>
    </section>
  )}

  <!-- ── Nearby towns in this area ── -->
  {nearbyTowns.length > 0 && (
    <section class="py-12 sm:py-16 bg-brand-dark border-t border-white/8">
      <div class="container mx-auto px-4 sm:px-6">

        <div class="mb-6 sm:mb-8">
          <span class="text-xs font-semibold tracking-widest uppercase text-brand-lime mb-3 block">
            {area.name}
          </span>
          <h2 class="text-xl sm:text-2xl font-bold text-white">
            Other Areas We Cover Nearby
          </h2>
        </div>

        <div class="flex flex-wrap gap-2.5">
          {nearbyTowns.map((t) => (
            <a
              href={`/areas/${area.slug}/${slugify(t)}`}
              title={`See our ${t} residential & trade services`}
              class="text-sm font-medium bg-brand-dark-card border border-white/10 text-white/60
                     rounded-full px-4 py-2
                     hover:border-brand-lime/40 hover:text-white
                     transition-all duration-200"
            >
              {t}
            </a>
          ))}
        </div>

        <p class="mt-6 text-xs text-white/40">
          View all&nbsp;
          <a href="/areas" class="text-brand-lime hover:underline underline-offset-2">coverage zones →</a>
        </p>
      </div>
    </section>
  )}

  <!-- ── FAQ ── -->
  <section class="py-12 sm:py-16 lg:py-20 bg-brand-dark border-t border-white/8" aria-labelledby="faq-heading">
    <div class="container mx-auto px-4 sm:px-6">
      <div class="max-w-2xl mx-auto">

        <span class="text-xs font-semibold tracking-widest uppercase text-brand-lime mb-3 block">
          Common Questions
        </span>
        <h2 id="faq-heading" class="font-display text-2xl sm:text-3xl font-bold text-white mb-8">
          Frequently Asked Questions — {town}
        </h2>

        <dl class="flex flex-col gap-4">
          {[
            {
              q: `Do you offer household clearances in ${town}?`,
              a: `Yes — WasteWize UK provides full house clearances in ${town}, including furniture, appliances, and bulky items. We carry full public liability insurance and issue a Waste Transfer Note on every job.`,
            },
            {
              q: `Can businesses in ${town} get a free waste audit?`,
              a: `Yes. We offer a free on-site waste audit for commercial customers in ${town}. Our team will assess your current waste streams and recommend a compliant, cost-effective collection schedule.`,
            },
            {
              q: `How quickly can you collect waste in ${town}?`,
              a: `We offer same-week availability across ${town} and the surrounding ${area.name} area. In many cases we can arrange next-day collection — call 07929 771954 for availability.`,
            },
            {
              q: `Are you EA-licensed to collect waste in ${town}?`,
              a: `Yes. WasteWize UK holds an Environment Agency Waste Carrier Licence (CBDU335711), covering all collections in ${town} and across London and the Home Counties. You will receive a Duty of Care Waste Transfer Note on every collection.`,
            },
          ].map(({ q, a }) => (
            <div class="bg-brand-dark-card border border-white/10 rounded-[12px] p-6">
              <dt class="text-[15px] font-semibold text-white mb-2 flex items-start gap-3">
                <span class="text-brand-lime shrink-0 mt-0.5" aria-hidden="true">Q</span>
                {q}
              </dt>
              <dd class="text-sm leading-relaxed text-white/60 pl-6">{a}</dd>
            </div>
          ))}
        </dl>

      </div>
    </div>
  </section>

  <!-- ── CTA ── -->
  <section class="py-12 sm:py-16 lg:py-20 bg-brand-dark-card border-t border-white/8">
    <div class="container mx-auto px-4 sm:px-6">
      <div class="max-w-2xl mx-auto text-center">
        <span class="text-xs font-semibold tracking-widest uppercase text-brand-lime mb-3 block">
          Ready to Book?
        </span>
        <h2 class="font-display text-2xl sm:text-3xl font-bold text-white mb-3">
          Get a Quote for {town}
        </h2>
        <p class="text-sm sm:text-base text-white/60 leading-relaxed mb-8 max-w-md mx-auto">
          Call us for an instant price or fill in the enquiry form and we'll get back to you
          within a few hours — same-week availability across {area.name}.
        </p>

        <div class="flex flex-col sm:flex-row items-center justify-center gap-3">
          <a
            href="tel:+447929771954"
            class="w-full sm:w-auto inline-flex items-center justify-center gap-2
                   bg-brand-forest text-white px-7 py-3.5 rounded-[8px] text-sm font-semibold
                   hover:bg-brand-forest-dark hover:shadow-cta hover:-translate-y-0.5
                   transition-all duration-200"
          >
            <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
            </svg>
            07929 771954
          </a>
          <a
            href="/contact"
            class="w-full sm:w-auto inline-flex items-center justify-center gap-2
                   border border-white/20 text-white/80 px-7 py-3.5 rounded-[8px] text-sm font-semibold
                   hover:border-brand-lime/50 hover:text-white
                   transition-all duration-200"
          >
            Send an Enquiry
            <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/>
