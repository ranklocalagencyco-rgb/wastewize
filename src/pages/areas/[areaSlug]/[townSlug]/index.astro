</Layout>

<script define:vars={{ TOWN_SERVICES: svcForJs }} is:inline>

  const grid    = document.getElementById('town-svc-grid');
  const panel   = document.getElementById('town-detail-panel');
  const countEl = document.getElementById('town-svc-count');
  const detTitle = document.getElementById('town-detail-title');
  const detDesc  = document.getElementById('town-detail-desc');
  const detPills = document.getElementById('town-detail-pills');
  const detLink  = document.getElementById('town-detail-link');
  const detPath  = document.getElementById('town-detail-icon-path');

  let activeCat = 'all';
  let activeId  = null;

  document.querySelectorAll('.town-filter-tab').forEach(function(btn) {
    btn.addEventListener('click', function() {
      activeCat = btn.dataset.townCat;
      activeId  = null;

      document.querySelectorAll('.town-filter-tab').forEach(function(b) {
        var isActive = b.dataset.townCat === activeCat;
        b.setAttribute('aria-pressed', String(isActive));
        b.classList.toggle('bg-brand-forest',    isActive);
        b.classList.toggle('text-white',          isActive);
        b.classList.toggle('border-brand-forest', isActive);
        b.classList.toggle('bg-brand-dark-card',  !isActive);
        b.classList.toggle('text-white/70',       !isActive);
        b.classList.toggle('border-white/15',     !isActive);
      });

      applyFilter();
      closePanel();
    });
  });

  function applyFilter() {
    var cards = grid.querySelectorAll('.town-svc-card');
    var visible = 0;
    cards.forEach(function(card) {
      var show = activeCat === 'all' || card.dataset.townCat === activeCat;
      card.style.display = show ? '' : 'none';
      if (show) visible++;
    });
    var total = TOWN_SERVICES.length;
    countEl.innerHTML = '<span class="w-2 h-2 rounded-full bg-brand-lime inline-block mr-2" aria-hidden="true"></span>' +
      (visible === total ? 'Showing all ' + total + ' services' : 'Showing ' + visible + ' of ' + total + ' services');
  }

  function toggleCard(id) {
    var wasOpen = activeId === id;
    resetCards();
    activeId = wasOpen ? null : id;
    if (activeId) { highlightCard(activeId); openPanel(activeId); }
    else          { closePanel(); }
  }

  function resetCards() {
    grid.querySelectorAll('.town-svc-card').forEach(function(c) {
      c.setAttribute('aria-expanded', 'false');
      c.classList.remove('border-brand-lime', 'bg-brand-dark-elevated', 'shadow-card', '-translate-y-1');
      var accent  = c.querySelector('.town-card-accent');
      var chevron = c.querySelector('.town-card-chevron');
      if (accent)  accent.style.transform = '';
      if (chevron) chevron.style.transform = '';
    });
  }

  function highlightCard(id) {
    var card = grid.querySelector('[data-town-id="' + id + '"]');
    if (!card) return;
    card.setAttribute('aria-expanded', 'true');
    card.classList.add('border-brand-lime', 'bg-brand-dark-elevated', 'shadow-card', '-translate-y-1');
    var accent  = card.querySelector('.town-card-accent');
    var chevron = card.querySelector('.town-card-chevron');
    if (accent)  accent.style.transform = 'scaleX(1)';
    if (chevron) chevron.style.transform = 'rotate(180deg)';
  }

  function openPanel(id) {
    var svc = TOWN_SERVICES.find(function(s) { return s.id === id; });
    if (!svc) return;
    detTitle.textContent = svc.title;
    detDesc.textContent  = svc.desc;
    detPath.setAttribute('d', svc.icon);
    detLink.href         = svc.areaHref;
    detPills.innerHTML   = svc.pills
      .map(function(p) { return '<span class="text-xs font-semibold px-3 py-1 rounded-full bg-brand-dark-elevated border border-brand-lime/20 text-white/60">' + p + '</span>'; })
      .join('');
    panel.classList.remove('hidden');
    panel.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
  }

  function closePanel() {
    panel.classList.add('hidden');
  }

  grid.querySelectorAll('.town-svc-card').forEach(function(card) {
    card.addEventListener('click', function() { toggleCard(card.dataset.townId); });
    card.addEventListener('keydown', function(e) {
      if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); toggleCard(card.dataset.townId); }
    });
  });
</script>
