---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Sustainability & Environmental Policy | WasteWize UK"
  description="WasteWize UK achieves a 99% landfill diversion rate through circular economy processing, carbon-optimised routing, and EA-licensed compliance — helping London businesses reach their net-zero targets."
>

  <Fragment slot="head">
    <script type="application/ld+json" is:inline set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "WasteWize UK",
      "url": "https://wastewize.co.uk",
      "description": "WasteWize UK provides EA-licensed commercial and residential waste management across London and the Home Counties with a 99% landfill diversion rate.",
      "hasCredential": [
        { "@type": "EducationalOccupationalCredential", "credentialCategory": "Environmental Agency Waste Carrier Licence" },
        { "@type": "EducationalOccupationalCredential", "credentialCategory": "WEEE Compliance Registration" }
      ],
      "knowsAbout": ["Circular Economy", "Waste Diversion", "Recycling", "Carbon Reduction", "WEEE Recycling", "Confidential Waste Destruction"],
      "slogan": "99% Landfill Diversion. Zero Compromise."
    })} />

    <script type="application/ld+json" is:inline set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home",           "item": "https://wastewize.co.uk/" },
        { "@type": "ListItem", "position": 2, "name": "Sustainability", "item": "https://wastewize.co.uk/sustainability" }
      ]
    })} />

    <script type="application/ld+json" is:inline set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebPage",
      "name": "Sustainability & Environmental Policy | WasteWize UK",
      "description": "WasteWize UK's sustainability commitment: 99% landfill diversion, circular economy material processing, carbon-optimised routing, and full EA-licensed duty-of-care documentation on every job.",
      "url": "https://wastewize.co.uk/sustainability",
      "inLanguage": "en-GB",
      "breadcrumb": {
        "@type": "BreadcrumbList",
        "itemListElement": [
          { "@type": "ListItem", "position": 1, "name": "Home",           "item": "https://wastewize.co.uk/" },
          { "@type": "ListItem", "position": 2, "name": "Sustainability", "item": "https://wastewize.co.uk/sustainability" }
        ]
      }
    })} />

    <script type="application/ld+json" is:inline set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebPage",
      "name": "Sustainability and Environmental Policy | WasteWize UK",
      "description": "Information on WasteWize UK's environmental impact, 99% landfill diversion rate, and EA compliance.",
      "mainEntity": {
        "@type": "Thing",
        "name": "Circular Economy",
        "description": "WasteWize UK focuses on the circular economy by sorting and recycling waste to prevent landfill usage."
      }
    })} />

    <meta property="og:title"       content="Sustainability & Environmental Policy | WasteWize UK" />
    <meta property="og:description" content="99% landfill diversion rate. Circular economy material processing. Carbon-optimised logistics. EA-licensed duty-of-care on every collection across London and the Home Counties." />
    <meta property="og:type"         content="website" />
    <meta property="og:url"          content="https://wastewize.co.uk/sustainability" />
    <meta name="twitter:title"       content="Sustainability & Environmental Policy | WasteWize UK" />
    <meta name="twitter:description" content="WasteWize UK operates at 99% landfill diversion across London and the Home Counties. Full circular economy. EA licensed. Digital duty-of-care on every job." />

    <meta name="keywords" content="sustainable waste management London, circular economy waste, landfill diversion, EA licensed waste carrier, carbon neutral waste collection, WEEE recycling London, eco waste management Home Counties, duty of care waste documentation" />
  </Fragment>

  <nav aria-label="Breadcrumb" class="bg-brand-dark border-b border-white/8">
    <div class="container mx-auto px-4 sm:px-6 py-3">
      <ol class="flex flex-wrap items-center gap-1.5 text-xs text-white/40">
        <li><a href="/"               class="hover:text-white/70 transition-colors">Home</a></li>
        <li aria-hidden="true" class="text-white/20">/</li>
        <li class="text-white/70" aria-current="page">Sustainability</li>
      </ol>
    </div>
  </nav>

  <main class="bg-brand-dark text-white">

    <section class="py-20 px-6 border-b border-white/8 relative overflow-hidden" aria-labelledby="sustainability-heading">
      <div class="absolute top-0 right-0 w-1/2 h-full bg-brand-lime/5 blur-3xl rounded-full -mr-64 -mt-64" aria-hidden="true"></div>

      <div class="container mx-auto max-w-6xl relative z-10">
        <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">

          <!-- Left: text -->
          <div>
            <span class="text-brand-lime font-bold uppercase tracking-widest text-sm mb-4 block">Our Commitment</span>
            <h1 id="sustainability-heading" class="font-display text-4xl md:text-5xl lg:text-6xl font-extrabold mb-6 leading-tight">
              Paving the Way for <span class="text-brand-lime italic">Zero Waste</span>
            </h1>
            <p class="text-lg text-white/60 leading-relaxed">
              At WasteWize UK, sustainability isn't an afterthought — it's the core of our logistics.
              We currently operate at a <strong class="text-white font-semibold">99% landfill diversion rate</strong> across
              all London and Home Counties sites, with a clear roadmap toward carbon-neutral collections.
            </p>

            <div class="mt-8 flex flex-wrap gap-3">
              <a
                href="/contact#quote"
                class="inline-flex items-center gap-2 bg-brand-forest text-white px-6 py-3 rounded-[8px]
                       text-sm font-semibold hover:bg-brand-forest-dark hover:shadow-cta hover:-translate-y-0.5
                       transition-all duration-200"
              >
                Get a sustainable waste quote
                <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/>
                </svg>
              </a>
              <a
                href="/services"
                class="inline-flex items-center gap-2 border border-white/20 text-white/80 px-6 py-3 rounded-[8px]
                       text-sm font-semibold hover:border-brand-lime/50 hover:text-white transition-all duration-200"
              >
                View our services
              </a>
            </div>
          </div>

          <!-- Right: image -->
          <div class="flex flex-col items-center gap-3">
            <div class="rounded-[16px] overflow-hidden border border-white/10 shadow-[0_8px_40px_rgba(0,0,0,0.4)] w-full">
              <img
                src="/circular-economy.png"
                alt="Circular Economy diagram showing the Production, Use, and Recycling stages — WasteWize UK"
                class="w-full h-auto block"
                loading="eager"
                width="640"
                height="352"
              />
            </div>
            <p class="text-white/25 text-[10px] uppercase tracking-[0.2em] font-medium text-center">
              Production → Use → Recycling → Recovery
            </p>
          </div>

        </div>
      </div>
    </section>


    <!-- ── Circular economy flow diagram ── -->
    <section class="py-20 px-6 border-b border-white/8">
      <div class="container mx-auto max-w-5xl">
        <div class="text-center mb-10">
          <span class="text-xs font-semibold tracking-widest uppercase text-brand-lime mb-3 block">Our Process</span>
          <h2 class="font-display text-3xl sm:text-4xl font-bold text-white">How WasteWize Collects, Sorts, and Recovers Your Waste</h2>
          <p class="mt-3 text-sm text-white/50 max-w-xl mx-auto">Every tonne we collect follows a documented chain — from your site to its final recovered destination.</p>
        </div>

        <!-- Flow steps -->
        <div class="relative">
          <!-- Connecting line (desktop) -->
          <div class="hidden lg:block absolute top-10 left-[10%] right-[10%] h-[2px] bg-gradient-to-r from-brand-lime/20 via-brand-lime/50 to-brand-lime/20" aria-hidden="true"></div>

          <div class="grid grid-cols-2 lg:grid-cols-5 gap-6 lg:gap-4 relative z-10">
            {[
              {
                step: '01',
                icon: 'M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z',
                title: 'Collection',
                desc:  'EA-licensed pickup from your site',
              },
              {
                step: '02',
                icon: 'M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2',
                title: 'Documentation',
                desc:  'Digital WTN issued immediately',
              },
              {
                step: '03',
                icon: 'M4 6h16M4 10h16M4 14h16M4 18h16',
                title: 'Segregation',
                desc:  'Materials sorted by stream at source',
              },
              {
                step: '04',
                icon: 'M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z',
                title: 'Processing',
                desc:  'Recycled, composted, or recovered',
              },
              {
                step: '05',
                icon: 'M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15',
                title: 'Reuse',
                desc:  '99% diverted from landfill',
              },
            ].map(({ step, icon, title, desc }) => (
              <div class="flex flex-col items-center text-center gap-3">
                <div class="w-20 h-20 rounded-full bg-brand-dark-card border-2 border-brand-lime/30
                            flex items-center justify-center relative shrink-0
                            hover:border-brand-lime hover:bg-brand-lime/10 transition-all duration-300 group/step">
                  <svg class="w-8 h-8 text-brand-lime group-hover/step:scale-110 transition-transform duration-300"
                       fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" d={icon}/>
                  </svg>
                  <span class="absolute -top-2 -right-2 w-6 h-6 rounded-full bg-brand-lime text-[10px]
                               font-bold text-brand-dark flex items-center justify-center leading-none">
                    {step}
                  </span>
                </div>
                <div>
                  <p class="text-sm font-semibold text-white mb-1">{title}</p>
                  <p class="text-[11px] text-white/40 leading-snug">{desc}</p>
                </div>
              </div>
            ))}
          </div>
        </div>

        <p class="mt-10 text-center text-white/25 text-[11px] uppercase tracking-[0.2em] font-medium">
          Visual Roadmap: From Collection to Material Recovery
        </p>
      </div>
    </section>

    <section class="py-20 px-6 bg-brand-dark-card border-b border-white/8" aria-labelledby="pillars-heading">
      <div class="container mx-auto max-w-6xl">
        <div class="max-w-xl mb-12">
          <span class="text-xs font-semibold tracking-widest uppercase text-brand-lime mb-3 block">How We Work</span>
          <h2 id="pillars-heading" class="font-display text-3xl sm:text-4xl font-bold text-white">
            How WasteWize UK Achieves 99% Landfill Diversion
          </h2>
        </div>

        <div class="grid md:grid-cols-3 gap-8 lg:gap-12">
          <article class="space-y-4">
            <div class="w-12 h-12 bg-brand-lime/20 rounded-[10px] flex items-center justify-center text-brand-lime font-bold text-lg" aria-hidden="true">01</div>
            <h3 class="text-2xl font-bold text-white">Circular Economy: Materials Redistributed, Not Landfilled</h3>
            <p class="text-white/50 leading-relaxed">
              We don't just remove waste — we redistribute materials. Every load is sorted at source
              so that wood, metal, aggregates, and plastics find a second life through certified
              recycling partners, diverting the maximum possible volume from landfill.
            </p>
          </article>

          <article class="space-y-4">
            <div class="w-12 h-12 bg-brand-lime/20 rounded-[10px] flex items-center justify-center text-brand-lime font-bold text-lg" aria-hidden="true">02</div>
            <h3 class="text-2xl font-bold text-white">Carbon Optimisation: Fewer Vehicles, Less Fuel per Tonne</h3>
            <p class="text-white/50 leading-relaxed">
              Our routing engine plans every collection to minimise empty mileage and fuel
              consumption. Consolidated loads, smart scheduling, and depot-proximity matching
              mean fewer vehicles on the road for the same volume of waste collected.
            </p>
          </article>

          <article class="space-y-4">
            <div class="w-12 h-12 bg-brand-lime/20 rounded-[10px] flex items-center justify-center text-brand-lime font-bold text-lg" aria-hidden="true">03</div>
            <h3 class="text-2xl font-bold text-white">Full Compliance: Digital Waste Transfer Notes on Every Collection</h3>
            <p class="text-white/50 leading-relaxed">
              Every job includes a digital Waste Transfer Note (WTN) providing 100% traceability
              from collection point to end destination. Our EA-licensed status, WEEE registrations,
              and duty-of-care records give clients complete regulatory peace of mind.
            </p>
          </article>
        </div>
      </div>
    </section>

    <section class="py-16 sm:py-20 px-4 sm:px-6 border-b border-white/8" aria-labelledby="impact-heading">
      <div class="container mx-auto max-w-5xl">
        <h2 id="impact-heading" class="text-2xl sm:text-3xl font-bold mb-8 sm:mb-10 text-center text-white">WasteWize UK Environmental Performance: Key Figures</h2>
        <div class="bg-white/5 border border-white/10 rounded-[20px] p-8 sm:p-12 lg:p-16">
          <div class="grid grid-cols-2 lg:grid-cols-4 gap-8 sm:gap-10">
            {[
              { value: '99%',     label: 'Landfill Diversion Rate' },
              { value: '0%',      label: 'Fly-Tipping Tolerance'   },
              { value: '100%',    label: 'EA Licensed Jobs'         },
              { value: 'Digital', label: 'Duty of Care Docs'        },
            ].map(({ value, label }) => (
              <div class="text-center">
                <p class="text-3xl sm:text-4xl font-bold text-brand-lime mb-2">{value}</p>
                <p class="text-xs text-white/40 uppercase tracking-wider leading-snug">{label}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <section class="py-20 px-6 bg-brand-dark-card border-b border-white/8" aria-labelledby="streams-heading">
      <div class="container mx-auto max-w-6xl">
        <div class="max-w-xl mb-12">
          <span class="text-xs font-semibold tracking-widest uppercase text-brand-lime mb-3 block">Material Streams</span>
          <h2 id="streams-heading" class="font-display text-3xl sm:text-4xl font-bold text-white">
            What Happens to Your Waste
          </h2>
          <p class="mt-3 text-sm text-white/50 leading-relaxed">
            We segregate at source and track every tonne through to its final destination.
          </p>
        </div>

        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
          {[
            {
              icon: 'M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16',
              title: 'Wood & Timber',
              desc:  'Chipped and processed into biomass energy or panel board, keeping timber out of landfill entirely.',
            },
            {
              icon: 'M6 3v9a6 6 0 0012 0V3M6 3h3m6 0h3M6 3v3m12-3v3',
              title: 'Scrap Metal',
              desc:  'Ferrous and non-ferrous metals are segregated and sent to licensed smelters for full material recovery.',
            },
            {
              icon: 'M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4',
              title: 'Hardcore & Rubble',
              desc:  'Crushed and graded on-site or at a licensed processing facility, then reused as secondary aggregate.',
            },
            {
              icon: 'M13 10V3L4 14h7v7l9-11h-7z',
              title: 'Electrical (WEEE)',
              desc:  'All electrical equipment is handled by WEEE-registered contractors with transfer notes issued for every load.',
            },
            {
              icon: 'M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z',
              title: 'Green & Garden Waste',
              desc:  'Grass, branches, and soil are diverted to certified composting facilities, producing PAS 100 compost.',
            },
            {
              icon: 'M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z',
              title: 'Confidential Waste',
              desc:  'Documents and data-bearing media are securely destroyed and audited, with certificates of destruction issued.',
            },
          ].map(({ icon, title, desc }) => (
            <article class="group bg-brand-dark border border-white/10 rounded-[12px] p-6 flex gap-4
                            hover:border-brand-lime/30 transition-colors duration-300">
              <div class="w-10 h-10 rounded-[8px] bg-brand-lime/10 flex items-center justify-center shrink-0 mt-0.5
                          group-hover:bg-brand-lime/20 transition-colors">
                <svg class="w-5 h-5 text-brand-lime" fill="none" stroke="currentColor" stroke-width="1.7"
                     viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d={icon}/>
                </svg>
              </div>
              <div>
                <h3 class="text-[15px] font-semibold text-white mb-1.5">{title}</h3>
                <p class="text-xs text-white/50 leading-relaxed">{desc}</p>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="py-20 px-6 border-b border-white/8" aria-labelledby="compliance-heading">
      <div class="container mx-auto max-w-6xl">
        <div class="max-w-xl mb-10">
          <span class="text-xs font-semibold tracking-widest uppercase text-brand-lime mb-3 block">Credentials</span>
          <h2 id="compliance-heading" class="font-display text-3xl sm:text-4xl font-bold text-white">
            Which Licences Does WasteWize UK Hold?
          </h2>
          <p class="mt-3 text-sm text-white/50 leading-relaxed">
            We hold every licence and registration required to legally handle your waste —
            giving you full legal indemnity and a complete audit trail.
          </p>
        </div>

        <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-5">
          {[
            { badge: 'EA',         title: 'Environment Agency',     desc: 'Upper-tier waste carrier, broker, and dealer registration. Legally authorised to collect, transport, and broker all waste types.' },
            { badge: 'WEEE',       title: 'WEEE Compliance',        desc: 'Registered for the collection and treatment of Waste Electrical and Electronic Equipment under UK WEEE Regulations.' },
            { badge: 'WTN',        title: 'Waste Transfer Notes',   desc: 'Digital WTNs issued for every collection — satisfying your duty-of-care obligations under the Environmental Protection Act 1990.' },
            { badge: 'GDPR',       title: 'Data & GDPR',            desc: 'Confidential waste destruction is fully GDPR and DPA 2018 compliant. Certificate of destruction issued on every collection.' },
          ].map(({ badge, title, desc }) => (
            <article class="bg-brand-dark-card border border-white/10 rounded-[12px] p-6 flex flex-col gap-3">
              <span class="inline-flex items-center justify-center w-12 h-12 rounded-[10px] bg-brand-lime/15
                           border border-brand-lime/30 text-brand-lime text-sm font-bold tracking-wide">
                {badge}
              </span>
              <h3 class="text-[15px] font-semibold text-white">{title}</h3>
              <p class="text-xs text-white/50 leading-relaxed flex-1">{desc}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="py-20 px-6 bg-brand-dark-card">
      <div class="container mx-auto max-w-3xl text-center">
        <span class="text-xs font-semibold tracking-widest uppercase text-brand-lime mb-3 block">Work With Us</span>
        <h2 class="font-display text-3xl sm:text-4xl font-bold text-white mb-4">
          Make Your Next Job Zero to Landfill
        </h2>
        <p class="text-sm sm:text-base text-white/60 leading-relaxed mb-10 max-w-xl mx-auto">
          Every WasteWize UK collection comes with a digital Waste Transfer Note, EA-licensed
          disposal, and a named contact who can account for every tonne from your site to its
          final destination.
        </p>
        <div class="flex flex-col sm:flex-row items-center justify-center gap-3">
          <a
            href="/contact#quote"
            class="w-full sm:w-auto inline-flex items-center justify-center gap-2 bg-brand-forest
                   text-white px-7 py-3.5 rounded-[8px] text-sm font-semibold
                   hover:bg-brand-forest-dark hover:shadow-cta hover:-translate-y-0.5
                   transition-all duration-200"
          >
            Get a free waste quote
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/>
            </svg>
          </a>
          <a
            href="tel:+447929771954"
            class="w-full sm:w-auto inline-flex items-center justify-center gap-2 border border-white/20
                   text-white/80 px-7 py-3.5 rounded-[8px] text-sm font-semibold
                   hover:border-brand-lime/50 hover:text-white transition-all duration-200"
          >
            <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
            </svg>
            07929 771954
          </a>
        </div>
      </div>
    </section>

  </main>

</Layout>
